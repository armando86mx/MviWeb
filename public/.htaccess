# MVI Amor y Gracia — .htaccess de producción
# Vive en public/ para viajar con cada build (el rsync --delete no lo borra).
# Directivas conservadoras compatibles con Apache y LiteSpeed (Hostinger).

# Nuestro home manda: inmune a un index.php residual (p.ej. el "Próximamente"
# de Hostinger, que LiteSpeed prioriza por default y el deploy FTP no borra)
DirectoryIndex index.html index.php

# ── Canónico: HTTPS + sin www (una sola forma de URL para SEO) ──
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Nada de .git servible por web (lo deja el clon del botón Desplegar de hPanel)
  RewriteRule ^\.git(/.*)?$ - [F,L]

  # Solo el dominio principal: este .htaccess se hereda hacia las carpetas
  # de los subdominios (p.ej. app/) y no debe redirigirlos.
  RewriteCond %{HTTP_HOST} ^(www\.)?amorygraciapuebla\.org$ [NC]
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\. [NC]
  RewriteRule ^ https://amorygraciapuebla.org%{REQUEST_URI} [L,R=301]

  # /visitanos se fusionó en /contacto (301 real; el HTML de respaldo
  # con meta-refresh queda para hosts sin mod_rewrite)
  RewriteRule ^visitanos/?$ /contacto [L,R=301]
</IfModule>

# El estado del deploy por FTP (GitHub Actions) no es público
<Files ".ftp-deploy-sync-state.json">
  Require all denied
</Files>

# ── Cabeceras de seguridad básicas ──
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Caché por tipo: CSS/JS/fuentes de Astro van con hash en el nombre,
#    así que un año es seguro; el HTML siempre fresco ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 week"
</IfModule>
