---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import CTABand from '@components/sections/CTABand.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';

const title = 'Crecer 3 — La iglesia que crece · 5 pilares Hechos 2:42 · Amor y Gracia';
const description = 'Crecer 3 es el tercer nivel de la serie Crecer. Aborda los 5 pilares de la iglesia primitiva según Hechos 2:42: adoración, enseñanza, comunión, oración y partimiento del pan.';
---

<BaseLayout title={title} description={description} path="/recursos/crecer-3">
  <SchemaBreadcrumb
    slot="head"
    items={[
      { name: 'Inicio', href: '/' },
      { name: 'Recursos', href: '/recursos' },
      { name: 'Crecer 3', href: '/recursos/crecer-3' },
    ]}
  />

  <Hero
    eyebrow="Serie Crecer · Nivel 3"
    title="Crecer 3 — La iglesia que crece"
    subtitle="Los 5 pilares de la iglesia primitiva según Hechos 2:42, y cómo siguen sosteniendo a la iglesia hoy."
  />

  <section class="section">
    <div class="container container--prose stack-lg">
      <Breadcrumbs items={[
        { label: 'Inicio', href: '/' },
        { label: 'Recursos', href: '/recursos' },
        { label: 'Crecer 3 — La iglesia que crece' },
      ]} />

      <p class="eyebrow">¿De qué trata?</p>
      <h2>Hechos 2:42 — los hábitos que sostuvieron a la iglesia primitiva.</h2>
      <p>
        Crecer 3 es la <strong>página doctrinal central</strong> de Amor y Gracia. Si
        Crecer 1 es para el creyente nuevo y Crecer 2 para el discípulo en consolidación, Crecer
        3 es para el creyente que quiere entender qué es ser <strong>iglesia local</strong>, no
        solo creyente individual.
      </p>
      <p>
        El material está construido alrededor de Hechos 2:42 y los <strong>cinco pilares</strong>
        que sostuvieron a la iglesia primitiva: intimidad en adoración, enseñanza, comunión,
        oración y partimiento del pan. Cada pilar tiene un capítulo dedicado con pasajes,
        explicación y aplicación práctica.
      </p>

      <h3>Los 5 pilares</h3>
      <ol>
        <li><strong>Intimidad en adoración</strong> — Juan 4:23-24. La adoración como respuesta del corazón, no como espectáculo.</li>
        <li><strong>Enseñanza</strong> — 2 Timoteo 3:16-17. La predicación expositiva y la sana doctrina como columna vertebral.</li>
        <li><strong>Comunión</strong> — Hechos 2:44-46. Hacer iglesia es hacer familia.</li>
        <li><strong>Oración</strong> — 1 Tesalonicenses 5:17. No como recurso de emergencia, sino como aire de la iglesia.</li>
        <li><strong>Partimiento del pan</strong> — Lucas 22:19-20. La mesa que recuerda quiénes somos.</li>
      </ol>

      <h3>Lo que vas a aprender</h3>
      <ul>
        <li>Por qué la iglesia local no es opcional para el creyente.</li>
        <li>Cómo distinguir una iglesia bíblica de una que solo lo parece.</li>
        <li>Por qué los 5 pilares son el patrón normativo, no una iglesia de moda.</li>
        <li>Cómo se vive cada pilar en una congregación pequeña como la nuestra.</li>
        <li>El énfasis escatológico: ser <strong>la novia que espera al novio</strong>.</li>
      </ul>

      <h3>¿Para quién es?</h3>
      <ul>
        <li><strong>Para quien ya completó Crecer 1 y 2</strong> y quiere entender la iglesia.</li>
        <li><strong>Para creyentes maduros</strong> que necesitan refrescar la doctrina eclesiológica.</li>
        <li><strong>Para líderes de pequeños grupos</strong> que quieren formar a su gente con calma.</li>
      </ul>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow text-center stack-lg">
      <p class="eyebrow">Descarga gratuita</p>
      <h2>Completa la serie</h2>
      <p class="lead mx-auto">Los tres niveles, gratis: descárgalos directo o pídelos a tu correo.</p>
      <div>
        <Button variant="primary" size="lg" href="/recursos/descargar">Descargar la serie completa</Button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <Card variant="subtle" href="/recursos/crecer-1">
          <p class="eyebrow">Volver al inicio</p>
          <h3>Crecer 1 — Fundamentos</h3>
          <p>Si necesitas refrescar los fundamentos.</p>
        </Card>
        <Card variant="subtle" href="/recursos/crecer-2">
          <p class="eyebrow">Nivel intermedio</p>
          <h3>Crecer 2 — Hábitos del discípulo</h3>
          <p>Los hábitos cotidianos del discípulo.</p>
        </Card>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Conversación"
    title="¿Te interesa una iglesia que viva los 5 pilares?"
    subtitle="Es justamente lo que somos. Si vives en Puebla, Amozoc o Tehuacán, ven a conocernos."
    primaryCTA={{ label: 'Cómo nos reunimos', href: '/como-nos-reunimos' }}
    secondaryCTA={{ label: 'Lo que creemos', href: '/lo-que-creemos' }}
  />
</BaseLayout>
