---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import PilaresGrid from '@components/sections/PilaresGrid.astro';
import EventoCard from '@components/sections/EventoCard.astro';
import PastoresCard from '@components/sections/PastoresCard.astro';
import CTABand from '@components/sections/CTABand.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import SchemaChurch from '@components/seo/SchemaChurch.astro';
import SchemaReligiousOrg from '@components/seo/SchemaReligiousOrg.astro';
import SchemaEvent from '@components/seo/SchemaEvent.astro';
import { SITE } from '@lib/site';

const title = 'MVI Amor y Gracia · Iglesia Cristiana Evangélica en Puebla';
const description = 'Iglesia cristiana evangélica en Amozoc, Puebla. Servicios dominicales 11:00 AM, Tiempos de Mesa los jueves. Pequeños en tamaño, profundos en doctrina, esperando el regreso de Cristo.';

const eventos = [
  {
    name: 'Servicio dominical',
    description: 'Estudio bíblico 10:30 AM, servicio completo 11:00 AM.',
    recurringDayOfWeek: 'Sunday' as const,
    startTime: '10:30',
    endTime: '12:30',
    locationName: 'MVI Amor y Gracia · Sede Amozoc',
    streetAddress: SITE.sedes.amozoc.streetAddress,
    addressLocality: 'Amozoc',
    addressRegion: 'Puebla',
    url: `${SITE.url}/sedes/amozoc`,
  },
  {
    name: 'Tiempos de Mesa',
    description: 'Estudio en casa de la familia Jiménez, jueves 7:30 PM.',
    recurringDayOfWeek: 'Thursday' as const,
    startTime: '19:30',
    endTime: '21:00',
    locationName: 'Casa de la familia Jiménez · Tiempos de Mesa',
    streetAddress: '[PLACEHOLDER: Domicilio Tiempos de Mesa, Amozoc]',
    addressLocality: 'Amozoc',
    addressRegion: 'Puebla',
    url: `${SITE.url}/como-nos-reunimos`,
  },
];
---

<BaseLayout title={title} description={description} path="/">
  <SchemaChurch slot="head" variant="main" />
  <SchemaReligiousOrg slot="head" />
  <SchemaEvent slot="head" events={eventos} />

  <Hero
    eyebrow="MVI · Amozoc · Tehuacán · Puebla"
    title="Iglesia Cristiana Evangélica en Puebla – MVI Amor y Gracia"
    subtitle="Pequeños en tamaño, profundos en doctrina. Una iglesia que estudia la Biblia con calma y espera con gozo el regreso de Cristo."
    primaryCTA={{ label: 'Visítanos un domingo', href: '/visitanos' }}
    secondaryCTA={{ label: 'Conoce lo que creemos', href: '/lo-que-creemos' }}
    variant="home"
  />

  <!-- Mensaje de identidad -->
  <section class="section">
    <div class="container container--narrow text-center stack-lg">
      <p class="eyebrow">Una invitación honesta</p>
      <h2 class="text-balance">
        En Amozoc y Tehuacán — abiertos a Puebla — somos una iglesia evangélica pequeña en tamaño pero profunda en doctrina.
      </h2>
      <p class="lead" style="margin-inline:auto;">
        Si estás buscando una congregación donde sentarte con la Palabra sin prisa,
        donde la mesa sea más importante que el escenario, y donde se hable con seriedad del
        regreso de Jesús — bienvenido a casa.
      </p>
      <p class="lead italic" style="margin-inline:auto; font-family: var(--font-display);">
        Somos iglesia · Hacemos iglesia · Hacemos familia.
      </p>
    </div>
  </section>

  <!-- Pilares -->
  <section class="section section--alt">
    <PilaresGrid />
    <div class="container text-center" style="margin-top: var(--sp-7);">
      <Button variant="secondary" href="/lo-que-creemos">Lee nuestra confesión completa →</Button>
    </div>
  </section>

  <!-- Eventos -->
  <section class="section">
    <div class="container">
      <header class="block-header">
        <p class="eyebrow">Cómo nos reunimos</p>
        <h2>Ven a sentarte con nosotros</h2>
        <p class="lead">Dos espacios principales cada semana. Uno en el templo, otro alrededor de una mesa.</p>
      </header>

      <div class="grid grid--2" style="margin-top: var(--sp-6);">
        <EventoCard
          title="Servicio dominical"
          weekday="Domingos"
          time="11:00 AM"
          location="Sede Amozoc · [PLACEHOLDER: dirección]"
          description="Estudio bíblico a las 10:30 AM, servicio completo a las 11:00 AM. Familias bienvenidas."
        />
        <EventoCard
          title="Tiempos de Mesa"
          weekday="Jueves"
          time="7:30 PM"
          location="Casa de la familia Jiménez, Amozoc"
          description="Estudio bíblico en casa, alrededor de una mesa. Pequeños grupos, conversación profunda, comida compartida."
          variant="mesa"
          badge="Hogar"
        />
      </div>

      <div class="text-center" style="margin-top: var(--sp-7);">
        <Button variant="secondary" href="/como-nos-reunimos">Ver calendario completo →</Button>
      </div>
    </div>
  </section>

  <!-- Pastores -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <header class="block-header">
        <p class="eyebrow">Conoce a los pastores</p>
        <h2>Daniel y Rocío Chávez</h2>
      </header>
      <div style="margin-top: var(--sp-5);">
        <PastoresCard />
      </div>
      <div class="text-center" style="margin-top: var(--sp-6);">
        <Button variant="secondary" href="/nosotros">Conoce su historia →</Button>
      </div>
    </div>
  </section>

  <!-- Recursos -->
  <section class="section">
    <div class="container">
      <header class="block-header">
        <p class="eyebrow">Recursos</p>
        <h2>La serie Crecer — material introductorio</h2>
        <p class="lead">
          Tres niveles de estudio bíblico que usamos en la iglesia para acompañar a quienes
          dan sus primeros pasos en la fe. Disponibles para descarga gratuita.
        </p>
      </header>

      <div class="grid grid--3" style="margin-top: var(--sp-6);">
        <Card href="/recursos/crecer-1">
          <p class="recurso__n">01 · Fundamentos</p>
          <h3>Crecer 1</h3>
          <p>Qué es ser hijo de Dios, qué es la Biblia, y por qué seguir a Cristo.</p>
        </Card>
        <Card href="/recursos/crecer-2">
          <p class="recurso__n">02 · Hábitos del discípulo</p>
          <h3>Crecer 2</h3>
          <p>Estudio bíblico, oración, y cómo la Palabra transforma el entendimiento.</p>
        </Card>
        <Card href="/recursos/crecer-3">
          <p class="recurso__n">03 · La iglesia que crece</p>
          <h3>Crecer 3</h3>
          <p>Los 5 pilares de la iglesia primitiva según Hechos 2:42.</p>
        </Card>
      </div>

      <div class="text-center" style="margin-top: var(--sp-7);">
        <Button variant="primary" size="lg" href="/recursos/descargar">Descargar la serie completa</Button>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <CTABand
    eyebrow="Visítanos"
    title="Las puertas están abiertas. La mesa está puesta."
    subtitle="Si estás buscando una iglesia donde sentarte con la Palabra y conocer a Jesús sin prisa, escríbenos. No hay requisitos. Solo bienvenida."
    primaryCTA={{ label: 'Escríbenos', href: '/contacto' }}
    secondaryCTA={{ label: 'Cómo llegar a Amozoc', href: '/sedes/amozoc' }}
  />
</BaseLayout>

<style>
  .block-header { max-width: 60ch; margin-bottom: var(--sp-5); }
  .recurso__n {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-azul-deep);
    margin-bottom: var(--sp-2);
  }
</style>
