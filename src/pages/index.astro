---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import PilaresGrid from '@components/sections/PilaresGrid.astro';
import EventoCard from '@components/sections/EventoCard.astro';
import PastoresCard from '@components/sections/PastoresCard.astro';
import CTABand from '@components/sections/CTABand.astro';
import MediosRow from '@components/sections/MediosRow.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import ScriptureQuote from '@components/ui/ScriptureQuote.astro';
import fotoHero from '@assets/img/foto-hero.webp';
import SchemaChurch from '@components/seo/SchemaChurch.astro';
import SchemaReligiousOrg from '@components/seo/SchemaReligiousOrg.astro';
import { SITE, SCRIPTURE_HERO } from '@lib/site';

const title = 'MVI Amor y Gracia · Iglesia Cristiana Evangélica en Puebla';
const description = 'Iglesia cristiana evangélica en Amozoc, Puebla. Domingos 11:00 AM y Tiempos de Mesa los jueves. Profundos en doctrina, esperando el regreso de Cristo.';

---

<BaseLayout title={title} description={description} path="/">
  <SchemaChurch slot="head" variant="main" />
  <SchemaReligiousOrg slot="head" />

  <Hero
    eyebrow="Amozoc · Tehuacán"
    title="Iglesia Cristiana Evangélica en Puebla –"
    titleAccent="MVI Amor y Gracia"
    subtitle="Una iglesia que estudia la Biblia con calma y profundidad en doctrina mientras espera con gozo el regreso de Cristo."
    primaryCTA={{ label: 'Visítanos un domingo', href: '/contacto' }}
    secondaryCTA={{ label: 'Conoce lo que creemos', href: '/lo-que-creemos' }}
    variant="home"
    photo={fotoHero}
    photoAlt="Nuestra nueva ubicación: C. 4 Nte. 207, Barrio, San Antonio, 72980 Amozoc de Mota, Pue. — Estás en casa"
  />

  <!-- Versículo del hero -->
  <section class="section section--tight">
    <div class="container container--narrow">
      <ScriptureQuote tone="cream" text={SCRIPTURE_HERO.text} reference={SCRIPTURE_HERO.reference} />
    </div>
  </section>

  <!-- Mensaje de identidad -->
  <section class="section">
    <div class="container container--narrow text-center stack-lg">
      <p class="eyebrow">Una invitación honesta</p>
      <h2 class="text-balance">
        Una iglesia pequeña en tamaño, profunda en doctrina.
      </h2>
      <p class="lead mx-auto">
        Estamos en Amozoc y Tehuacán, abiertos a toda Puebla. Si buscas una congregación
        donde sentarte con la Palabra sin prisa, donde la mesa sea más importante que el
        escenario, y donde se hable con seriedad del regreso de Jesús — bienvenido a casa.
      </p>
    </div>
  </section>

  <!-- Pilares -->
  <section class="section section--alt">
    <PilaresGrid />
    <div class="container text-center mt-7">
      <Button variant="secondary" href="/lo-que-creemos">Lee nuestra confesión completa →</Button>
    </div>
  </section>

  <!-- Eventos -->
  <section class="section">
    <div class="container">
      <header class="block-header">
        <p class="eyebrow">Cómo nos reunimos</p>
        <h2>Ven a sentarte con nosotros</h2>
        <p class="lead">Dos espacios principales cada semana. Uno en el templo, otro alrededor de una mesa.</p>
      </header>

      <div class="grid grid--2 mt-6">
        <EventoCard
          title="Servicio dominical"
          weekday="Domingos"
          time="11:00 AM"
          location="Sede Amozoc · Amozoc, Puebla"
          description="Estudio bíblico a las 10:30 AM, servicio completo a las 11:00 AM. Familias bienvenidas."
        />
        <EventoCard
          title="Tiempos de Mesa"
          weekday="Jueves"
          time="7:30 PM"
          location="Casa familiar, Amozoc"
          description="Estudio bíblico en casa, alrededor de una mesa. Pequeños grupos, conversación profunda, comida compartida."
          variant="mesa"
          badge="Hogar"
        />
      </div>

      <div class="text-center mt-7">
        <Button variant="secondary" href="/como-nos-reunimos">Ver horarios y reuniones →</Button>
      </div>
    </div>
  </section>

  <!-- Prédicas y podcast (solo se pinta con cuentas configuradas en SITE.media) -->
  <MediosRow />

  <!-- Pastores -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <header class="block-header">
        <p class="eyebrow">Conoce a los pastores</p>
        <h2>Daniel y Rocío Chávez</h2>
      </header>
      <div class="mt-5">
        <PastoresCard showHeading={false} />
      </div>
      <div class="text-center mt-6">
        <Button variant="secondary" href="/nosotros">Conoce su historia →</Button>
      </div>
    </div>
  </section>

  <!-- Recursos -->
  <section class="section section--invert recursos">
    <div class="container">
      <header class="block-header">
        <p class="eyebrow">Recursos</p>
        <h2>La serie Crecer — material introductorio</h2>
        <p class="lead">
          Tres niveles de estudio bíblico que usamos en la iglesia para acompañar a quienes
          dan sus primeros pasos en la fe. Disponibles para descarga gratuita.
        </p>
      </header>

      <div class="grid grid--3 mt-6">
        <Card href="/recursos/crecer-1" variant="dark">
          <p class="recurso__n"><span class="recurso__n-num">01</span> · Fundamentos</p>
          <h3>Crecer 1</h3>
          <p>Qué es ser hijo de Dios, qué es la Biblia, y por qué seguir a Cristo.</p>
        </Card>
        <Card href="/recursos/crecer-2" variant="dark">
          <p class="recurso__n"><span class="recurso__n-num">02</span> · Hábitos del discípulo</p>
          <h3>Crecer 2</h3>
          <p>Estudio bíblico, oración, y cómo la Palabra transforma el entendimiento.</p>
        </Card>
        <Card href="/recursos/crecer-3" variant="dark">
          <p class="recurso__n"><span class="recurso__n-num">03</span> · La iglesia que crece</p>
          <h3>Crecer 3</h3>
          <p>Los 5 pilares de la iglesia primitiva según Hechos 2:42.</p>
        </Card>
      </div>

      <div class="text-center mt-7">
        <Button variant="amber" size="lg" href="/recursos/descargar">Descargar la serie completa</Button>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <CTABand
    eyebrow="Visítanos"
    title="Las puertas están abiertas. La mesa está puesta."
    subtitle="Si estás buscando una iglesia donde sentarte con la Palabra y conocer a Jesús sin prisa, escríbenos. No hay requisitos. Solo bienvenida."
    primaryCTA={{ label: 'Escríbenos', href: '/contacto' }}
    secondaryCTA={{ label: 'Cómo llegar a Amozoc', href: '/sedes/amozoc' }}
  />
</BaseLayout>

<style>
  .block-header { max-width: 60ch; margin-bottom: var(--sp-5); }

  /* Banda navy de recursos (§7.7): numerito en círculo + tipografía sobre oscuro */
  .recurso__n {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--amber-400);
    margin-bottom: var(--sp-3);
  }
  .recurso__n-num {
    display: grid;
    place-content: center;
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid var(--amber-500);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--amber-400);
  }
  .recursos h3 {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-xl);
    color: var(--cream-text-2);
  }
  .recursos .grid--3 p:not(.recurso__n) {
    color: var(--slate-text-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
  }
</style>
