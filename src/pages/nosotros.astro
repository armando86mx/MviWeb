---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import PastoresCard from '@components/sections/PastoresCard.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import SchemaReligiousOrg from '@components/seo/SchemaReligiousOrg.astro';
import SchemaPerson from '@components/seo/SchemaPerson.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import { SITE, PASTORAL_QUOTE } from '@lib/site';

const title = 'Nosotros · Pastores Daniel y Rocío Chávez · Amor y Gracia';
const description = 'Conoce a MVI Amor y Gracia: una iglesia evangélica fundada en marzo de 2014 en Amozoc, Puebla, pastoreada por el matrimonio Daniel y Rocío Chávez. Bajo cobertura de Ministerios Visión Internacional.';
---

<BaseLayout title={title} description={description} path="/nosotros">
  <SchemaReligiousOrg slot="head" />
  <SchemaPerson
    slot="head"
    name={SITE.pastors.daniel}
    jobTitle="Pastor fundador"
    description="Pastor de MVI Amor y Gracia desde su fundación en marzo de 2014, en Amozoc, Puebla."
    spouse={SITE.pastors.rocio}
  />
  <SchemaPerson
    slot="head"
    name={SITE.pastors.rocio}
    jobTitle="Pastora fundadora"
    description="Pastora de MVI Amor y Gracia desde su fundación en marzo de 2014, en Amozoc, Puebla."
    spouse={SITE.pastors.daniel}
  />
  <SchemaBreadcrumb slot="head" items={[{ name: 'Inicio', href: '/' }, { name: 'Nosotros', href: '/nosotros' }]} />

  <Hero
    eyebrow="Quiénes somos"
    title="Conoce a MVI Amor y Gracia – Pastores Daniel y Rocío"
    subtitle="Una congregación pequeña en tamaño y profunda en doctrina, fundada en marzo de 2014 en Amozoc, Puebla."
  />

  <section class="section">
    <div class="container container--prose stack-lg">
      <p class="eyebrow">Nuestra historia</p>
      <h2>Nacimos como mesa, no como escenario.</h2>
      <p>
        En marzo de 2014, un grupo pequeño se sentó a estudiar la Biblia con calma en Amozoc,
        Puebla. No éramos muchos, y eso nos permitió conocernos profundamente. De ese inicio
        salió todo lo que somos: una iglesia que valora más la mesa compartida que el escenario,
        más el estudio paciente de la Palabra que el espectáculo, y más la familia que el
        número.
      </p>
      <p>
        Hoy seguimos siendo pequeños, pero el Señor nos ha extendido. Tenemos una iglesia hija
        en Tehuacán con su propio liderazgo local, abrimos las puertas para hermanos de Puebla
        capital y zonas conurbadas que viajan los domingos, y operamos bajo la cobertura de
        <a href={SITE.parentOrganization.url} rel="noopener noreferrer" target="_blank">Ministerios Visión Internacional<span class="sr-only"> (se abre en ventana nueva)</span></a>,
        red ministerial seria con presencia en varias ciudades de México y el mundo.
      </p>

      <figure class="founding">
        <blockquote class="founding__quote">
          En marzo del 2014 Dios nos llamó a formar parte de sus mensajeros para
          extender su mensaje — el evangelio completo: ser testigos fieles de su
          Palabra, de lo que Él hizo, está haciendo y hará. El anhelo de nuestro
          corazón es preparar una iglesia digna de Él.
        </blockquote>
        <figcaption>Del testimonio de fundación de los pastores · el llamado de marzo de 2014</figcaption>
      </figure>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <p class="eyebrow eyebrow--block text-center">Frase pastoral</p>
      <blockquote class="quote-pastoral">
        “{PASTORAL_QUOTE.text}”
        <cite>— {PASTORAL_QUOTE.attribution}</cite>
      </blockquote>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <header class="block-header">
        <p class="eyebrow">Pastores fundadores</p>
        <h2>Daniel y Rocío Chávez</h2>
        <p class="lead">
          Matrimonio que pastorea Amor y Gracia desde su fundación. Cálidos por naturaleza,
          comprometidos con la sana doctrina y con caminar cerca de cada miembro de la familia.
        </p>
      </header>
      <div class="mt-5">
        <PastoresCard showHeading={false} />
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="block-header text-center mx-auto">
        <p class="eyebrow">Nuestra cobertura</p>
        <h2>Bajo Ministerios Visión Internacional (MVI)</h2>
        <p class="lead">
          Estamos vinculados a una red ministerial seria con presencia internacional, lo que nos
          da raíces, supervisión pastoral y comunión con iglesias hermanas como MVI Querétaro y
          otras congregaciones en México, América Latina y otros países.
        </p>
      </header>

      <div class="grid grid--3 mt-6">
        <Card variant="subtle">
          <h3>Sede principal</h3>
          <p>Amozoc, Puebla. Servicios dominicales y Tiempos de Mesa los jueves.</p>
          <p class="mt-4"><Button variant="ghost" href="/sedes/amozoc">Conocer la sede →</Button></p>
        </Card>
        <Card variant="subtle">
          <h3>Iglesia hija</h3>
          <p>Tehuacán, Puebla, con su propio liderazgo local pero gestionada en comunión con la sede principal.</p>
          <p class="mt-4"><Button variant="ghost" href="/sedes/tehuacan">Conocer Tehuacán →</Button></p>
        </Card>
        <Card variant="subtle">
          <h3>Puebla capital</h3>
          <p>Sin sede física, pero abiertos a recibir a quien venga desde la capital y zonas satélites cada domingo.</p>
          <p class="mt-4"><Button variant="ghost" href="/puebla">Cómo nos visita Puebla →</Button></p>
        </Card>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .block-header { max-width: 60ch; margin-bottom: var(--sp-5); }
  .quote-pastoral {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-quote);
    line-height: var(--lh-snug);
    color: var(--blue-700);
    text-align: center;
    margin: 0;
    padding: var(--sp-7) 0 0;
    border: 0;
    text-wrap: balance;
  }
  .quote-pastoral cite {
    display: block;
    margin-top: var(--sp-5);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ochre-600);
  }

  .founding { margin: var(--sp-6) 0; }
  .founding__quote {
    background: var(--paper-300);
    border: 0;
    border-radius: var(--radius-md);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
    color: var(--blue-700);
    text-wrap: pretty;
  }
  .founding figcaption {
    text-align: center;
    margin-top: var(--sp-3);
    font-family: var(--font-body);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--tan-500);
  }
</style>
