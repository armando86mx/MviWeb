---
import BlogLayout from '@layouts/BlogLayout.astro';
import CTABand from '@components/sections/CTABand.astro';
import Card from '@components/ui/Card.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'> }

const { post } = Astro.props;
const { Content } = await post.render();
const path = `/blog/${post.slug}`;

// "Sigue leyendo": el post más reciente distinto al actual
const others = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const nextPost = others[0];
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  author={post.data.author}
  ogImage={post.data.heroImage}
  path={path}
>
  <Content />

  <Fragment slot="after">
    {nextPost && (
      <section class="section--tight related">
        <div class="container container--prose">
          <p class="eyebrow">Sigue leyendo</p>
          <Card href={`/blog/${nextPost.slug}`}>
            <h2 class="related__title">{nextPost.data.title}</h2>
            <p>{nextPost.data.description}</p>
          </Card>
        </div>
      </section>
    )}

    <CTABand
      eyebrow="Visítanos"
      title="¿Buscas una iglesia donde estudiar esto en comunidad?"
      subtitle="Lo que lees aquí es lo que vivimos los domingos y los jueves. Ven a sentarte con nosotros — sin requisitos, solo bienvenida."
      primaryCTA={{ label: 'Qué esperar en tu visita', href: '/contacto#primera-visita' }}
      secondaryCTA={{ label: 'Cómo nos reunimos', href: '/como-nos-reunimos' }}
    />
  </Fragment>
</BlogLayout>

<style>
  .related { padding-bottom: var(--sp-9); }
  .related .eyebrow { margin-bottom: var(--sp-4); }
  .related__title { font-size: var(--fs-lg); margin-bottom: var(--sp-3); text-wrap: balance; }
</style>
