---
// Banner LFPDPPP — controla GA4 mediante consent.
// Aparece sólo si no hay decisión previa.
---
<aside id="cookie-banner" class="cookie-banner" hidden aria-live="polite" aria-label="Aviso de cookies">
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      Este sitio puede usar Google Analytics y Microsoft Clarity para entender cómo se usa la página.
      No recopilamos datos personales sin tu consentimiento. Puedes aceptar o rechazar
      las cookies analíticas en cualquier momento.
      <a href="/aviso-de-privacidad">Consulta el aviso de privacidad</a>.
    </p>
    <div class="cookie-banner__actions">
      <button type="button" class="cookie-banner__btn cookie-banner__btn--secondary" data-cookie-decline>Rechazar</button>
      <button type="button" class="cookie-banner__btn cookie-banner__btn--primary" data-cookie-accept>Aceptar analíticas</button>
    </div>
  </div>
</aside>

<style>
  .cookie-banner {
    position: fixed;
    inset: auto var(--sp-4) var(--sp-4) var(--sp-4);
    z-index: var(--z-toast);
    max-width: 640px;
    margin-inline: auto;
    background: var(--paper-100);
    color: var(--ink);
    border: 1px solid var(--paper-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    padding: var(--sp-5);
  }
  .cookie-banner[hidden] { display: none; }
  .cookie-banner__inner {
    display: grid;
    gap: var(--sp-4);
  }
  .cookie-banner__text {
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0;
  }
  .cookie-banner__actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .cookie-banner__btn {
    font-family: var(--font-body);
    border-radius: var(--radius-pill);
    padding: 0.6rem 1.2rem;
    min-height: 44px; /* target táctil */
    font-size: var(--fs-sm);
    border: 0;
    cursor: pointer;
    transition: transform var(--dur-btn) var(--ease),
                box-shadow var(--dur-btn) var(--ease),
                background-color var(--dur-btn) var(--ease),
                color var(--dur-btn) var(--ease);
  }
  /* Receta primary: azul, sombra navy → ámbar en hover */
  .cookie-banner__btn--primary {
    background: var(--blue-700);
    color: var(--cream-text);
    font-weight: var(--fw-bold);
    box-shadow: var(--shadow-btn);
  }
  @media (hover: hover) and (pointer: fine) {
    .cookie-banner__btn--primary:hover {
      background: var(--blue-700-hover);
      transform: translateY(-2px);
      box-shadow: var(--shadow-btn-hover);
    }
  }
  .cookie-banner__btn:active { transform: translateY(1px); }
  /* Receta secondary: subrayado ocre que se rellena de ámbar */
  .cookie-banner__btn--secondary {
    background: transparent;
    color: var(--ink);
    font-weight: var(--fw-semibold);
    text-decoration: underline;
    text-decoration-color: var(--ochre-500);
    text-underline-offset: 4px;
  }
  @media (hover: hover) and (pointer: fine) {
    .cookie-banner__btn--secondary:hover {
      background: var(--amber-500);
      color: var(--blue-cta-text); /* #fff daba 2.23:1 sobre ámbar */
      text-decoration: none;
      box-shadow: 0 16px 32px -14px rgba(223,162,78,0.7);
      transform: translateY(-2px);
    }
  }
</style>

<script>
  const KEY = 'mvi-cookie-consent-v1';
  const banner = document.getElementById('cookie-banner');
  const accept = document.querySelector('[data-cookie-accept]');
  const decline = document.querySelector('[data-cookie-decline]');

  function show() { banner?.removeAttribute('hidden'); }
  function hide() { banner?.setAttribute('hidden', ''); }

  const stored = localStorage.getItem(KEY);
  if (!stored) show();

  // "Preferencias de cookies" en el footer permite revocar/cambiar la decisión
  document.addEventListener('mvi:open-cookie-prefs', show);

  accept?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'granted');
    hide();
    document.dispatchEvent(new CustomEvent('mvi:consent-granted'));
  });
  decline?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'denied');
    hide();
  });
</script>
