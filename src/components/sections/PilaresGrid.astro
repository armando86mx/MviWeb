---
const pilares = [
  {
    n: '01',
    titulo: 'Intimidad en adoración',
    descripcion: 'No buscamos espectáculo. Buscamos rostro. La adoración es respuesta del corazón a un Dios real — sencilla, sostenida y central en todo lo que hacemos.',
    versiculo: 'Hechos 2:42 · Juan 4:23',
  },
  {
    n: '02',
    titulo: 'Enseñanza',
    descripcion: 'Sentarse con la Palabra, sin atajos. Abrimos la Biblia, la leemos en su contexto y dejamos que diga lo que dice. La sana doctrina edifica y sostiene en el tiempo.',
    versiculo: '2 Timoteo 3:16-17',
  },
  {
    n: '03',
    titulo: 'Comunión',
    descripcion: 'Hacer iglesia es hacer familia. Conocernos por nombre, cuidarnos en lo concreto y caminar juntos en lo cotidiano. El evangelio se ve mejor en la mesa que en el escenario.',
    versiculo: 'Hechos 2:44-46',
  },
  {
    n: '04',
    titulo: 'Oración',
    descripcion: 'No como recurso de emergencia, sino como aire de la iglesia. Oramos juntos y le pedimos al Señor que sostenga lo que hace. Sin oración, lo demás es activismo religioso.',
    versiculo: 'Hechos 2:42 · 1 Tesalonicenses 5:17',
  },
  {
    n: '05',
    titulo: 'Partimiento del pan',
    descripcion: 'La mesa de la comunión nos recuerda quiénes somos: la novia que espera al novio, sostenida por la cruz, esperando con gozo el regreso de Cristo.',
    versiculo: 'Lucas 22:19-20',
  },
];
---

<section class="pilares" aria-labelledby="pilares-heading">
  <div class="container container--narrow">
    <header class="pilares__header">
      <p class="eyebrow">Hechos 2:42</p>
      <h2 id="pilares-heading">Los 5 pilares de la iglesia primitiva</h2>
      <p class="lead">
        Cinco prácticas que sostuvieron a la iglesia en sus primeros días y siguen sosteniendo
        a Amor y Gracia hoy.
      </p>
    </header>

    <ol class="pilares__list" role="list">
      {pilares.map((p, i) => (
        <li>
          <details class="pilar" name="pilares" open={i === 0}>
            <summary class="pilar__summary">
              <span class="pilar__num" aria-hidden="true">{p.n}</span>
              <span class="pilar__title">{p.titulo}</span>
              <span class="pilar__chevron" aria-hidden="true"></span>
            </summary>
            <div class="pilar__body">
              <p class="pilar__desc">{p.descripcion}</p>
              <p class="pilar__ref">{p.versiculo}</p>
            </div>
          </details>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  // ponytail: <details name> ya es exclusivo nativo; esto solo cubre navegadores pre-2024
  document.querySelectorAll<HTMLDetailsElement>('.pilares__list details').forEach((d) => {
    d.addEventListener('toggle', () => {
      if (!d.open) return;
      document
        .querySelectorAll<HTMLDetailsElement>('.pilares__list details[open]')
        .forEach((o) => { if (o !== d) o.open = false; });
    });
  });
</script>

<style>
  .pilares__header { max-width: 60ch; margin-bottom: var(--sp-7); }

  .pilares__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
  }

  /* §7.6 · Tarjeta de pilar: crema, borde ámbar translúcido que se
     intensifica en hover con sombra ámbar y levantamiento.
     Ahora como acordeón exclusivo (details name="pilares"). */
  .pilar {
    background: var(--paper-100);
    border: 1.5px solid rgba(223,162,78,0.55);
    border-radius: var(--radius-card);
    interpolate-size: allow-keywords;
    transition: transform var(--dur-card) var(--ease),
                box-shadow var(--dur-card) var(--ease),
                border-color var(--dur-card) var(--ease);
  }
  .pilar:hover {
    border-color: rgba(223,162,78,0.95);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }

  /* Animación de apertura/cierre (progresiva: navegadores sin
     ::details-content simplemente abren sin transición) */
  .pilar::details-content {
    block-size: 0;
    overflow: hidden;
    transition: block-size var(--dur-card) var(--ease),
                content-visibility var(--dur-card) allow-discrete;
  }
  .pilar[open]::details-content { block-size: auto; }

  .pilar__summary {
    display: flex;
    gap: 30px;
    align-items: center;
    padding: 26px 36px;
    cursor: pointer;
    list-style: none;
  }
  .pilar__summary::-webkit-details-marker { display: none; }
  .pilar__summary:focus-visible {
    outline: 2px solid var(--amber-500, #DFA24E);
    outline-offset: 4px;
    border-radius: var(--radius-card);
  }

  .pilar__num {
    display: grid;
    place-content: center;
    flex: 0 0 auto;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--blue-700);
    color: var(--cream-text);
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: 19px;
  }

  .pilar__title {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-xl);
    line-height: var(--lh-snug);
    color: var(--blue-700);
    min-width: 0;
  }

  .pilar__chevron {
    flex: 0 0 auto;
    margin-left: auto;
    width: 11px;
    height: 11px;
    border-right: 2px solid var(--tan-500);
    border-bottom: 2px solid var(--tan-500);
    transform: rotate(45deg);
    transition: transform var(--dur-card) var(--ease);
  }
  .pilar[open] .pilar__chevron { transform: rotate(225deg); }

  .pilar__body { padding: 0 36px 30px calc(36px + 58px + 30px); }

  .pilar__desc {
    font-size: var(--fs-base);
    line-height: 1.6;
    color: var(--ink-body-80);
    margin: 0 0 var(--sp-3);
    max-width: 56ch;
  }

  .pilar__ref {
    font-family: var(--font-body);
    font-weight: var(--fw-semibold);
    font-size: 11.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tan-500);
    margin: 0;
  }

  @media (max-width: 560px) {
    .pilar__summary { gap: var(--sp-4); padding: 18px 22px; }
    .pilar__num { width: 44px; height: 44px; font-size: 16px; }
    .pilar__body { padding: 0 22px 22px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pilar, .pilar::details-content, .pilar__chevron { transition: none; }
    .pilar:hover { transform: none; }
  }
</style>
