---
/**
 * Prédicas y podcast en la home: fila de videos de YouTube y, debajo,
 * fila de episodios de Spotify. Cada bloque solo se pinta si su cuenta
 * está configurada en SITE.media y su fetch de build trajo contenido.
 * Todo con fachadas: nada de terceros hasta que el visitante pulsa play.
 */
import Button from '@components/ui/Button.astro';
import YouTubeEmbed from '@components/youtube/YouTubeEmbed.astro';
import SpotifyEpisode from '@components/spotify/SpotifyEpisode.astro';
import { SITE } from '@lib/site';
import { fetchLatestVideos, fetchLatestEpisodes } from '@lib/media';

const { youtubeChannel, spotifyShow } = SITE.media;
const videos = youtubeChannel ? await fetchLatestVideos(4) : [];
const episodios = spotifyShow ? await fetchLatestEpisodes(4) : [];
// La sección existe solo si algún bloque trae contenido real este build
const activo = videos.length > 0 || episodios.length > 0;
---

{activo && (
  <section class="section medios" aria-label="Prédicas y podcast">
    <div class="container">
      {youtubeChannel && videos.length > 0 && (
        <>
          <header class="medios__header">
            <p class="eyebrow">Prédicas recientes</p>
            <h2>Últimas enseñanzas <span class="u-nowrap">en <span class="marca-youtube">YouTube</span></span></h2>
          </header>

          <ul class="medios__row" role="list" aria-label="Prédicas recientes en YouTube">
            {videos.map((v) => (
              <li class="medios__item">
                <YouTubeEmbed videoId={v.id} title={v.title} />
                <p class="medios__title">{v.title}</p>
              </li>
            ))}
          </ul>

          <div class="medios__ctas">
            <Button variant="secondary" href={`${youtubeChannel}?sub_confirmation=1`} target="_blank" rel="noopener noreferrer">
              Suscribirse al canal<span class="sr-only"> (se abre en YouTube)</span>
            </Button>
            <Button variant="secondary" href={youtubeChannel} target="_blank" rel="noopener noreferrer">
              Ver el canal en YouTube<span class="sr-only"> (se abre en ventana nueva)</span>
            </Button>
          </div>
        </>
      )}

      {spotifyShow && episodios.length > 0 && (
        <div class="medios__podcast">
          <header class="medios__header">
            <p class="eyebrow">Podcast</p>
            <h2>Escúchanos en <span class="marca-spotify">Spotify</span></h2>
          </header>

          <ul class="medios__row" role="list" aria-label="Episodios recientes del podcast">
            {episodios.map((e) => (
              <li class="medios__item medios__item--sq">
                <SpotifyEpisode episodeId={e.id} title={e.title} cover={e.cover} />
                <p class="medios__title">{e.title}</p>
              </li>
            ))}
          </ul>

          <div class="medios__ctas">
            <Button variant="secondary" href={spotifyShow} target="_blank" rel="noopener noreferrer">
              Ver el podcast en Spotify<span class="sr-only"> (se abre en ventana nueva)</span>
            </Button>
          </div>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .medios__header { max-width: 60ch; margin-bottom: var(--sp-5); }

  /* La palabra de la plataforma en su color de marca (solo titular grande).
     "en" queda en el azul del titular; "en YouTube" no se parte en dos líneas. */
  .u-nowrap { white-space: nowrap; }
  .marca-youtube { color: var(--brand-youtube); }
  .marca-spotify { color: var(--brand-spotify); }

  /* Respiro simétrico: el mismo espacio que hay entre la fila y el botón
     (margen sp-5 + padding sp-3 de la fila) queda bajo el botón antes
     del bloque del podcast */
  .medios__ctas + .medios__podcast { margin-top: calc(var(--sp-5) + var(--sp-3)); }

  /* Fila deslizable con snap; en desktop caben las 4 */
  .medios__row {
    list-style: none;
    margin: 0 0 var(--sp-5);
    padding: 0 0 var(--sp-3);
    display: flex;
    gap: var(--sp-4);
    overflow-x: auto;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }
  .medios__item {
    flex: 0 0 min(320px, 82%);
    scroll-snap-align: start;
  }
  /* Episodios de Spotify: tarjetas cuadradas (formato de portada) */
  .medios__item--sq {
    flex: 0 0 min(264px, 70%);
  }
  .medios__title {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--ink);
    line-height: var(--lh-snug);
    /* Títulos largos (los episodios son frases completas): 2 líneas máx */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .medios__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    align-items: center;
  }
</style>
