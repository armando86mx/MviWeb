---
import { Image } from 'astro:assets';
import pastoresFoto from '@assets/img/pastores.jpg';

interface Props {
  layout?: 'horizontal' | 'stacked';
  /** Cuando la sección que envuelve la tarjeta ya muestra el nombre
      como encabezado, pasar false para no duplicarlo dentro. */
  showHeading?: boolean;
}
const { layout = 'horizontal', showHeading = true } = Astro.props;
---
<aside class={`pastores pastores--${layout}`}>
  <div class="pastores__media">
    <Image
      src={pastoresFoto}
      alt="Los pastores Daniel y Rocío Chávez, fundadores de MVI Amor y Gracia"
      class="pastores__photo"
      width={1280}
      widths={[600, 900, 1280]}
      sizes="(max-width: 800px) 100vw, 460px"
      quality={82}
    />
  </div>
  <div class="pastores__body">
    {showHeading && (
      <>
        <p class="eyebrow">Pastores fundadores</p>
        <h3>Daniel y Rocío Chávez</h3>
      </>
    )}
    <p>
      Matrimonio que pastorea Amor y Gracia desde su fundación en marzo de 2014. Cálidos por
      naturaleza, profundos en la enseñanza, comprometidos con caminar de cerca con la familia
      de la iglesia.
    </p>
    <blockquote class="pastores__quote">
      Somos enseñables. Y seguimos aprendiendo día con día buscando a Dios.
    </blockquote>
  </div>
</aside>

<style>
  /* Tarjeta crema firma, informativa: sin sombra ni hover */
  .pastores {
    background: var(--paper-100);
    border: 1.5px solid var(--border-amber);
    border-radius: var(--radius-card);
    padding: clamp(1.25rem, 3vw, 2rem);
    display: grid;
    gap: var(--sp-5);
  }
  .pastores--horizontal { grid-template-columns: 1fr; }
  @media (min-width: 800px) {
    .pastores--horizontal { grid-template-columns: minmax(220px, 280px) 1fr; gap: var(--sp-7); align-items: center; }
  }

  .pastores__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    /* Encuadre hacia la izquierda para que Rocío y Daniel queden centrados */
    object-position: 38% center;
    border-radius: var(--radius-md);
    display: block;
  }
  @media (min-width: 800px) {
    /* Algo más alto que el texto para anclar visualmente la tarjeta */
    .pastores--horizontal .pastores__media { align-self: stretch; }
    .pastores--horizontal .pastores__photo { height: 100%; aspect-ratio: auto; min-height: 340px; }
  }

  /* Hereda el blockquote global (barra ámbar, Newsreader itálica azul);
     solo se ajusta la escala y el margen al contexto de tarjeta */
  .pastores__quote {
    margin: var(--sp-4) 0 0;
    font-size: var(--fs-md);
  }
</style>
