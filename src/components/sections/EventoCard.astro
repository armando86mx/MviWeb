---
interface Props {
  title: string;
  weekday: string;
  time: string;
  location: string;
  description?: string;
  variant?: 'default' | 'mesa';
  badge?: string;
}
const { title, weekday, time, location, description, variant = 'default', badge } = Astro.props;
---
<article class={`evento evento--${variant}`}>
  {badge && <span class="evento__badge">{badge}</span>}
  <p class="evento__when">
    <span class="evento__day">{weekday}</span>
    <span class="evento__time">{time}</span>
  </p>
  <h3 class="evento__title">{title}</h3>
  <p class="evento__location">{location}</p>
  {description && <p class="evento__desc">{description}</p>}
</article>

<style>
  .evento {
    background: var(--paper-100);
    border: 1.5px solid rgba(223,162,78,0.55);
    border-radius: var(--radius-card);
    padding: clamp(1.5rem, 2vw, 2rem);
    position: relative;
    /* Sin sombra de reposo ni hover-lift: la tarjeta es informativa, no un enlace */
  }

  /* Tiempo de Mesa: mismo papel, borde ámbar más intenso */
  .evento--mesa {
    border-color: rgba(223,162,78,0.72);
  }

  .evento__badge {
    position: absolute;
    top: var(--sp-3);
    right: var(--sp-3);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
    background: var(--amber-500);
    color: var(--blue-cta-text);
    padding: 0.3em 0.7em;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .evento__when {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .evento__day {
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ochre-600);
  }
  .evento__time {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--fw-medium);
    color: var(--blue-700);
  }

  .evento__title {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-xl);
    color: var(--blue-700);
    margin-bottom: var(--sp-2);
  }
  .evento__location {
    font-size: var(--fs-sm);
    color: var(--ink-muted);
  }
  .evento__desc {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    color: var(--ink-body);
  }
</style>
