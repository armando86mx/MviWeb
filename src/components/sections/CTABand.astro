---
import Button from '@components/ui/Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCTA: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}
const { eyebrow, title, subtitle, primaryCTA, secondaryCTA } = Astro.props;
---
<section class="cta-band section section--invert">
  <div class="container container--cta cta-band__inner">
    <div>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="text-balance">{title}</h2>
      {subtitle && <p class="cta-band__sub">{subtitle}</p>}
    </div>
    <div class="cta-band__actions">
      <Button variant="amber" size="lg" href={primaryCTA.href}>{primaryCTA.label}</Button>
      {secondaryCTA && <Button variant="ghost" size="lg" href={secondaryCTA.href}>{secondaryCTA.label} <span aria-hidden="true">→</span></Button>}
    </div>
  </div>
</section>

<style>
  /* §7.12 · CTA sobre navy: luz de tarde + ~96px de respiro.
     Mantiene .section--invert (footer sin margen) y sobreescribe fondo/padding. */
  .cta-band.section {
    background: var(--warm-cta-dark);
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .cta-band.section h2 {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-2xl);
    color: var(--cream-text);
  }

  .cta-band__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: center;
  }
  @media (min-width: 800px) {
    .cta-band__inner { grid-template-columns: 1.4fr 1fr; gap: var(--sp-9); }
  }

  .cta-band__sub {
    color: var(--slate-text);
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    max-width: 56ch;
    margin-top: var(--sp-3);
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    justify-content: flex-start;
  }
  @media (min-width: 800px) {
    .cta-band__actions { justify-content: flex-end; }
  }
</style>
