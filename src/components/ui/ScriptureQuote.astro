---
interface Props {
  text: string;
  reference: string;
  /** Fondo de la cita: "cream" (marco de líneas de papel) o "navy"
      (panel oscuro con barra ámbar). */
  tone?: 'cream' | 'navy';
}
const { text, reference, tone = 'cream' } = Astro.props;
---
<figure class={`quote quote--${tone}`}>
  <blockquote>
    <p>“{text}”</p>
  </blockquote>
  <figcaption>{reference}</figcaption>
</figure>

<style>
  /* §7.10 · Cita — Newsreader itálica 1.4; sobre crema va enmarcada por
     líneas de papel, sobre navy lleva barra ámbar y fondo degradado */
  .quote {
    margin: 0;
  }
  .quote blockquote {
    margin: 0;
    border: 0;
    padding: 0;
  }
  .quote blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-regular);
    line-height: 1.4;
    margin: 0;
    max-width: 60ch;
  }
  .quote blockquote p { font-size: var(--fs-lg); }

  .quote figcaption {
    margin-top: var(--sp-3);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  /* (a) Sobre crema: el marco son los bordes arriba/abajo, sin barra */
  .quote--cream {
    background: var(--paper-200);
    border-top: 1px solid var(--paper-line);
    border-bottom: 1px solid var(--paper-line);
    padding: clamp(2rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.5rem);
  }
  .quote--cream blockquote p { color: var(--blue-700); }
  .quote--cream figcaption { color: var(--ochre-600); }

  /* (b) Sobre navy: panel oscuro con barra izquierda ámbar */
  .quote--navy {
    position: relative;
    background: linear-gradient(160deg, var(--blue-800), var(--blue-950));
    border-radius: var(--radius-md);
    padding: clamp(2rem, 4vw, 3rem) clamp(1.75rem, 4vw, 3rem);
  }
  .quote--navy::before {
    content: "";
    position: absolute;
    /* A medio camino entre el borde del panel y el texto (padding-left / 2) */
    left: calc(clamp(1.75rem, 4vw, 3rem) / 2 - 2px);
    top: clamp(2rem, 4vw, 3rem);
    bottom: clamp(2rem, 4vw, 3rem);
    width: 4px;
    border-radius: 2px;
    background: var(--amber-500);
  }
  .quote--navy blockquote p { color: var(--cream-text); }
  .quote--navy figcaption { color: var(--amber-400); }
</style>
