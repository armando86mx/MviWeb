---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'amber';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  rel?: string;
  target?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  disabled = false,
  fullWidth = false,
  rel,
  target,
  class: extraClass = '',
  ...rest
} = Astro.props;

const cls = [
  'btn',
  `btn--${variant}`,
  `btn--${size}`,
  fullWidth ? 'btn--full' : '',
  extraClass,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={cls} rel={rel} target={target} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={cls} disabled={disabled} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    line-height: 1;
    text-decoration: none;
    border: 0;
    border-radius: var(--radius-pill);
    cursor: pointer;
    text-align: center;
    transition: transform var(--dur-btn) var(--ease),
                box-shadow var(--dur-btn) var(--ease),
                background-color var(--dur-btn) var(--ease),
                color var(--dur-btn) var(--ease);
  }

  .btn:active { transform: translateY(1px); }
  .btn:disabled { opacity: 0.55; cursor: not-allowed; }

  /* Los hovers solo aplican con puntero real: en touch quedarían "pegados"
     tras el tap (levantamiento y relleno ámbar persistentes) */

  .btn--sm { padding: 10px 18px; font-size: var(--fs-sm); }
  .btn--md { padding: 15px 28px; font-size: var(--fs-base); }
  .btn--lg { padding: 17px 32px; font-size: var(--fs-md); }
  .btn--full { width: 100%; }

  /* Primario: azul profundo, sombra navy que pasa a ámbar en hover */
  .btn--primary {
    background-color: var(--blue-700);
    color: var(--cream-text);
    box-shadow: var(--shadow-btn-hero);
  }
  @media (hover: hover) and (pointer: fine) {
    .btn--primary:hover {
      background-color: var(--blue-700-hover);
      color: var(--cream-text);
      transform: translateY(-2px);
      box-shadow: var(--shadow-btn-hero-hover);
    }
  }

  /* CTA ámbar (sobre navy) */
  .btn--amber {
    background-color: var(--amber-500);
    color: var(--blue-cta-text);
    box-shadow: var(--shadow-cta-amber);
  }
  .btn--amber.btn--md { padding: 16px 30px; }
  @media (hover: hover) and (pointer: fine) {
    .btn--amber:hover {
      background-color: var(--amber-600);
      color: var(--blue-cta-text);
      transform: translateY(-2px);
      box-shadow: var(--shadow-cta-amber-hover);
    }
  }

  /* Secundario: enlace-botón subrayado que se rellena de ámbar en hover */
  .btn--secondary {
    background-color: transparent;
    color: var(--ink);
    font-weight: var(--fw-semibold);
    box-shadow: none;
    text-decoration: underline;
    text-decoration-color: var(--ochre-500);
    text-underline-offset: 4px;
  }
  .btn--secondary.btn--md { padding: 15px 22px; }
  @media (hover: hover) and (pointer: fine) {
    .btn--secondary:hover {
      background-color: var(--amber-500);
      color: var(--blue-cta-text); /* #fff daba 2.23:1 sobre ámbar; este par pasa AA (5.75:1) */
      text-decoration: none;
      box-shadow: 0 16px 32px -14px rgba(223,162,78,0.7);
      transform: translateY(-2px);
    }
  }

  /* Ghost: enlace de texto con subrayado ámbar */
  .btn--ghost {
    background-color: transparent;
    color: var(--blue-700);
    font-weight: var(--fw-semibold);
    box-shadow: none;
    text-decoration: underline;
    text-decoration-color: var(--amber-500);
    text-underline-offset: 4px;
    padding-inline: 0;
    border-radius: 0;
  }
  @media (hover: hover) and (pointer: fine) {
    .btn--ghost:hover { color: var(--ochre-700); }
  }

  /* Sobre fondos navy (hero oscuro, bandas CTA), ghost y secondary
     heredarían tinta sobre navy → texto invisible. Variantes claras.
     OJO: solo .hero--page — el hero de la home es CLARO (crema). */
  :global(.section--invert) .btn--ghost,
  :global(.hero--page) .btn--ghost {
    color: var(--slate-text);
  }
  :global(.section--invert) .btn--secondary,
  :global(.hero--page) .btn--secondary {
    color: var(--cream-text);
    text-decoration-color: var(--amber-500);
  }
  @media (hover: hover) and (pointer: fine) {
    :global(.section--invert) .btn--ghost:hover,
    :global(.hero--page) .btn--ghost:hover {
      color: var(--amber-400);
    }
    :global(.section--invert) .btn--secondary:hover,
    :global(.hero--page) .btn--secondary:hover {
      background-color: var(--amber-500);
      color: var(--blue-cta-text);
      text-decoration: none;
    }
  }
</style>
