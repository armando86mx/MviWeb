---
interface Props { tone?: 'azul' | 'mesa' | 'neutro'; }
const { tone = 'azul' } = Astro.props;
---
<span class={`badge badge--${tone}`}><slot /></span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.3em 0.75em;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    line-height: 1.2;
  }
  .badge--azul { background-color: var(--amber-tint); color: var(--blue-700); }
  .badge--mesa { background-color: var(--amber-500); color: var(--blue-cta-text); }
  .badge--neutro { background-color: var(--paper-300); color: var(--ink-muted); }
</style>
