---
/**
 * Migas de pan visibles para páginas profundas (sedes, recursos).
 * Complementan al SchemaBreadcrumb: Google espera que el dato
 * estructurado corresponda con algo visible en la página.
 */
interface Crumb {
  label: string;
  href?: string; // el último elemento (página actual) va sin href
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
<nav class="crumbs" aria-label="Ubicación en el sitio">
  <ol>
    {items.map((item, i) => (
      <li>
        {item.href ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
        {i < items.length - 1 && <span class="crumbs__sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .crumbs ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .crumbs li { display: inline-flex; align-items: center; gap: var(--sp-2); }
  .crumbs a {
    color: var(--ink-muted);
    text-decoration: none;
    padding-block: var(--sp-2); /* target táctil ≥24px */
    transition: color var(--dur-link) var(--ease);
  }
  .crumbs [aria-current="page"] { color: var(--ink); }
  .crumbs__sep { color: var(--paper-line-2); }

  @media (hover: hover) and (pointer: fine) {
    .crumbs a:hover { color: var(--ochre-700); text-decoration: none; }
  }
</style>
