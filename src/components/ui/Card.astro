---
interface Props {
  href?: string;
  variant?: 'default' | 'subtle' | 'mesa' | 'dark';
  class?: string;
}
const { href, variant = 'default', class: extraClass = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
const cls = ['card', `card--${variant}`, href ? 'card--link' : '', extraClass].filter(Boolean).join(' ');
---
<Tag class={cls} {...(href ? { href } : {})}>
  <slot />
</Tag>

<style>
  /* Tarjeta crema firma: borde ámbar translúcido sobre papel */
  .card {
    background-color: var(--paper-100);
    border: 1.5px solid var(--border-amber);
    border-radius: var(--radius-card);
    padding: clamp(1.25rem, 2vw, 1.75rem);
  }
  /* Solo las tarjetas-enlace transicionan/levantan: una tarjeta
     informativa que "flota" al hover sugiere un clic que no existe */
  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform var(--dur-card) var(--ease),
                box-shadow var(--dur-card) var(--ease),
                border-color var(--dur-card) var(--ease);
  }
  @media (hover: hover) and (pointer: fine) {
    .card--link:hover {
      border-color: var(--border-amber-hover);
      box-shadow: var(--shadow-card-hover);
      transform: translateY(-4px);
    }
  }
  /* Neutra: sin acento ámbar */
  .card--subtle {
    background-color: var(--paper-100);
    border: 1px solid var(--paper-line);
  }
  /* Tiempo de Mesa: mismo papel, borde ámbar más intenso */
  .card--mesa {
    border-color: var(--border-amber-mesa);
  }
  /* Tarjeta sobre banda navy (§7.7) */
  .card--dark {
    background-color: rgba(220,230,255,0.04);
    border: 1.5px solid var(--border-amber-mesa);
    border-radius: var(--radius-card-sm);
    padding: 28px;
  }
  @media (hover: hover) and (pointer: fine) {
    .card--dark.card--link:hover {
      border-color: rgba(223,162,78,0.9);
      box-shadow: var(--shadow-card-sm-hover);
      transform: translateY(-4px);
    }
  }
</style>
