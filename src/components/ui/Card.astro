---
interface Props {
  href?: string;
  variant?: 'default' | 'subtle' | 'mesa';
  class?: string;
}
const { href, variant = 'default', class: extraClass = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
const cls = ['card', `card--${variant}`, href ? 'card--link' : '', extraClass].filter(Boolean).join(' ');
---
<Tag class={cls} {...(href ? { href } : {})}>
  <slot />
</Tag>

<style>
  .card {
    background-color: var(--color-blanco);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 2vw, 1.75rem);
    transition: box-shadow var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
  }
  .card--subtle {
    background-color: var(--color-bg-alt);
    border-color: transparent;
  }
  .card--mesa {
    /* Pieza temática Tiempo de Mesa: paleta cálida marrón/vino, no se fuerza al azul */
    background: linear-gradient(180deg, #fbf3df 0%, #f3e2bf 100%);
    border-color: #e7d2a3;
    color: var(--color-mesa-vino);
  }
  .card--mesa h2, .card--mesa h3 { color: var(--color-mesa-vino); }
  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .card--link:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-azul-claro);
  }
</style>
