---
import { SITE } from '@lib/site';

interface Props {
  variant?: 'main' | 'amozoc' | 'tehuacan';
}

const { variant = 'main' } = Astro.props;

// Solo URLs reales — los campos vacíos no entran al JSON-LD
const SOCIAL: string[] = [
  SITE.social.facebook,
  SITE.social.instagram,
  SITE.social.youtube,
].filter((x) => x.length > 0);

const sede = variant === 'tehuacan' ? SITE.sedes.tehuacan : SITE.sedes.amozoc;
const id = variant === 'tehuacan'
  ? `${SITE.url}/sedes/tehuacan#church`
  : variant === 'amozoc'
    ? `${SITE.url}/sedes/amozoc#church`
    : `${SITE.url}/#church`;

const name = variant === 'tehuacan'
  ? 'MVI Amor y Gracia · Tehuacán'
  : variant === 'amozoc'
    ? 'MVI Amor y Gracia · Amozoc'
    : SITE.name;

// La descripción global habla de Amozoc; Tehuacán necesita la suya
const description = variant === 'tehuacan'
  ? 'Iglesia cristiana evangélica en Tehuacán, Puebla — iglesia hija de MVI Amor y Gracia (Amozoc), bajo cobertura de Ministerios Visión Internacional.'
  : SITE.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Church',
  '@id': id,
  name,
  alternateName: SITE.alternateNames,
  description,
  url: variant === 'main' ? `${SITE.url}/` : `${SITE.url}/sedes/${variant}`,
  logo: `${SITE.url}/favicon-512.png`,
  image: `${SITE.url}${SITE.ogImage}`,
  email: SITE.email,
  // Teléfono, calle, CP y geo entran al schema solo cuando son datos
  // confirmados: un dato provisional en Google es peor que ninguno.
  ...(sede.phone ? { telephone: sede.phone } : {}),
  address: {
    '@type': 'PostalAddress',
    ...(sede.streetAddress ? { streetAddress: sede.streetAddress } : {}),
    addressLocality: sede.city,
    addressRegion: sede.region,
    ...(sede.postalCode ? { postalCode: sede.postalCode } : {}),
    addressCountry: sede.country,
  },
  ...(sede.geoConfirmed
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: sede.latitude,
          longitude: sede.longitude,
        },
      }
    : {}),
  ...('mapsUrl' in sede && sede.mapsUrl ? { hasMap: sede.mapsUrl } : {}),
  // Horarios confirmados solo de Amozoc; Tehuacán aún no tiene horario público
  ...(variant !== 'tehuacan'
    ? {
        openingHoursSpecification: [
          {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: 'Sunday',
            opens: '10:30',
            closes: '12:30',
            description: 'Servicio dominical (estudio bíblico 10:30, servicio completo 11:00)',
          },
          {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: 'Thursday',
            opens: '19:30',
            closes: '21:00',
            description: 'Tiempos de Mesa (en una casa familiar)',
          },
        ],
      }
    : {}),
  parentOrganization: {
    '@type': 'ReligiousOrganization',
    name: SITE.parentOrganization.name,
    url: SITE.parentOrganization.url,
  },
  founder: [
    { '@type': 'Person', name: SITE.pastors.daniel },
    { '@type': 'Person', name: SITE.pastors.rocio },
  ],
  foundingDate: SITE.founded,
  areaServed: [
    { '@type': 'City', name: 'Puebla' },
    { '@type': 'City', name: 'Amozoc' },
    { '@type': 'City', name: 'Tehuacán' },
    { '@type': 'City', name: 'Cholula' },
    { '@type': 'City', name: 'San Andrés Cholula' },
    { '@type': 'City', name: 'San Pedro Cholula' },
    { '@type': 'City', name: 'Atlixco' },
  ],
  ...(SOCIAL.length > 0 ? { sameAs: SOCIAL } : {}),
  knowsAbout: [
    'Estudio bíblico',
    'Segunda venida de Cristo',
    'Adoración',
    'Comunión cristiana',
    'Oración',
    'Partimiento del pan',
    'Sana doctrina',
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
