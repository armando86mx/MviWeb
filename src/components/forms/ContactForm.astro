---
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '';
---

<form
  class="form"
  action="/api/contacto.php"
  method="POST"
  novalidate
  data-form="contacto"
  aria-describedby="form-help"
>
  <p id="form-help" class="form__help">
    Los campos marcados con <span aria-hidden="true">*</span> son obligatorios.
    Tu mensaje llegará a <strong>contacto@amorygraciapuebla.org</strong>.
  </p>

  <div class="form__row">
    <div class="field" data-field>
      <label class="field__label" for="ct-nombre">Nombre <span aria-hidden="true">*</span></label>
      <input id="ct-nombre" type="text" name="nombre" required minlength="2" maxlength="50" autocomplete="given-name" aria-describedby="ct-nombre-error" data-error-label="tu nombre" />
      <span class="field__error" id="ct-nombre-error" hidden></span>
    </div>
    <div class="field" data-field>
      <label class="field__label" for="ct-apellido">Apellido <span aria-hidden="true">*</span></label>
      <input id="ct-apellido" type="text" name="apellido" required minlength="2" maxlength="50" autocomplete="family-name" aria-describedby="ct-apellido-error" data-error-label="tu apellido" />
      <span class="field__error" id="ct-apellido-error" hidden></span>
    </div>
  </div>

  <div class="field" data-field>
    <label class="field__label" for="ct-email">Correo <span aria-hidden="true">*</span></label>
    <input id="ct-email" type="email" name="email" required maxlength="120" autocomplete="email" inputmode="email" aria-describedby="ct-email-error" data-error-label="tu correo" />
    <span class="field__error" id="ct-email-error" hidden></span>
  </div>

  <div class="field" data-field>
    <label class="field__label" for="ct-telefono">Teléfono <span class="field__optional">(opcional)</span></label>
    <input id="ct-telefono" type="tel" name="telefono" maxlength="20" autocomplete="tel" inputmode="tel" />
  </div>

  <div class="field" data-field>
    <label class="field__label" for="ct-motivo">Motivo <span aria-hidden="true">*</span></label>
    <select id="ct-motivo" name="motivo" required aria-describedby="ct-motivo-error" data-error-label="el motivo">
      <option value="" disabled selected>Selecciona una opción</option>
      <option value="visita">Quiero visitar la iglesia</option>
      <option value="oracion">Pedido de oración</option>
      <option value="consulta-pastoral">Consulta pastoral</option>
      <option value="otro">Otro</option>
    </select>
    <span class="field__error" id="ct-motivo-error" hidden></span>
  </div>

  <div class="field" data-field>
    <label class="field__label" for="ct-mensaje">Mensaje <span aria-hidden="true">*</span></label>
    <textarea id="ct-mensaje" name="mensaje" required minlength="10" maxlength="2000" rows={6} aria-describedby="ct-mensaje-error" data-error-label="tu mensaje"></textarea>
    <span class="field__error" id="ct-mensaje-error" hidden></span>
  </div>

  <!-- Honeypot: invisible para humanos, visible para bots -->
  <div class="hp" aria-hidden="true">
    <label>No llenar este campo:
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <input type="hidden" name="g-recaptcha-response" data-recaptcha-token />

  <div class="form__actions">
    <button type="submit" class="btn btn--primary btn--lg" data-submit>Enviar mensaje</button>
    <p class="form__legal">
      Al enviar aceptas nuestro <a href="/aviso-de-privacidad">aviso de privacidad</a>.
    </p>
  </div>

  <p class="form__status" data-form-status role="status" aria-live="polite"></p>
</form>

{recaptchaSiteKey && (
  <script is:inline async src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
)}

<style>
  .form { display: grid; gap: var(--sp-5); max-width: 600px; }
  .form__help { font-size: var(--fs-sm); color: var(--color-fg-muted); }
  .form__row { display: grid; gap: var(--sp-4); }
  @media (min-width: 600px) { .form__row { grid-template-columns: 1fr 1fr; } }

  .field { display: grid; gap: var(--sp-2); }
  .field__label {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-fg);
  }
  .field__optional {
    font-weight: var(--fw-regular);
    color: var(--color-fg-muted);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: var(--fs-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-blanco);
    color: var(--color-fg);
    transition: border-color var(--dur-1) var(--ease-out), box-shadow var(--dur-1) var(--ease-out);
  }
  .field textarea { resize: vertical; min-height: 8rem; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--color-azul-claro);
    box-shadow: 0 0 0 3px var(--color-azul-claro-50);
    outline: none;
  }

  /* El estado de error lo controla JS tras interacción del usuario —
     nunca al cargar la página (un formulario virgen no está "mal") */
  .field.is-invalid input,
  .field.is-invalid select,
  .field.is-invalid textarea { border-color: var(--color-error); }
  .field__error {
    font-size: var(--fs-xs);
    color: var(--color-error);
  }
  .field__error[hidden] { display: none; }

  .hp { position: absolute; left: -9999px; top: -9999px; visibility: hidden; }

  .form__actions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
  }
  @media (min-width: 600px) {
    .form__actions { flex-direction: row; align-items: center; }
  }
  .form__legal { font-size: var(--fs-xs); color: var(--color-fg-muted); }

  .form__status:not(:empty) {
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-md);
    background: var(--color-azul-claro-50);
    color: var(--color-azul-deep);
    font-size: var(--fs-sm);
  }
  .form__status[data-state="error"]:not(:empty) {
    background: var(--color-error-bg);
    color: var(--color-error);
  }
</style>

<script define:vars={{ recaptchaSiteKey }}>
  const form = document.querySelector('[data-form="contacto"]');
  // Selectores scoped al formulario: evita colisiones si conviven dos forms
  const status = form?.querySelector('[data-form-status]');
  const tokenInput = form?.querySelector('[data-recaptcha-token]');
  const submitBtn = form?.querySelector('[data-submit]');

  function messageFor(el) {
    const label = el.dataset.errorLabel || 'este campo';
    const v = el.validity;
    if (v.valueMissing) return `Escribe ${label}.`;
    if (v.typeMismatch && el.type === 'email') return 'Revisa el formato del correo (ej. nombre@correo.com).';
    if (v.tooShort) return `Un poco más largo, por favor (mínimo ${el.minLength} caracteres).`;
    return 'Revisa este campo.';
  }

  function setFieldState(el, touched) {
    const field = el.closest('[data-field]');
    const errorEl = field?.querySelector('.field__error');
    const valid = el.checkValidity();
    if (!field || !errorEl) return valid;
    if (valid || !touched) {
      field.classList.remove('is-invalid');
      el.removeAttribute('aria-invalid');
      errorEl.hidden = true;
      errorEl.textContent = '';
    } else {
      field.classList.add('is-invalid');
      el.setAttribute('aria-invalid', 'true');
      errorEl.hidden = false;
      errorEl.textContent = messageFor(el);
    }
    return valid;
  }

  const controls = form ? [...form.querySelectorAll('input[required], select[required], textarea[required]')] : [];
  controls.forEach((el) => {
    el.addEventListener('blur', () => setFieldState(el, true));
    el.addEventListener('input', () => {
      // Al corregir, retira el error en cuanto el campo sea válido
      if (el.closest('[data-field]')?.classList.contains('is-invalid')) setFieldState(el, true);
    });
  });

  async function getRecaptchaToken() {
    if (!recaptchaSiteKey || !window.grecaptcha) return '';
    return new Promise((resolve) => {
      window.grecaptcha.ready(async () => {
        try {
          const t = await window.grecaptcha.execute(recaptchaSiteKey, { action: 'contacto' });
          resolve(t);
        } catch { resolve(''); }
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    // Validación antes de enviar; foco al primer campo con error
    let firstInvalid = null;
    for (const el of controls) {
      const ok = setFieldState(el, true);
      if (!ok && !firstInvalid) firstInvalid = el;
    }
    if (firstInvalid) {
      firstInvalid.focus();
      status.setAttribute('data-state', 'error');
      status.textContent = 'Revisa los campos marcados antes de enviar.';
      return;
    }

    status.removeAttribute('data-state');
    status.textContent = 'Enviando…';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando…';
    }

    const t = await getRecaptchaToken();
    if (tokenInput) tokenInput.value = t;

    const data = new FormData(form);
    try {
      const r = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (!r.ok) throw new Error(String(r.status));
      const j = await r.json().catch(() => ({}));
      status.textContent = j.message ?? '¡Mensaje enviado! Te responderemos pronto.';
      form.reset();
    } catch (err) {
      status.setAttribute('data-state', 'error');
      status.textContent = 'No pudimos enviar tu mensaje. Inténtalo de nuevo en unos minutos o escríbenos directo a contacto@amorygraciapuebla.org';
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar mensaje';
      }
    }
  });
</script>
