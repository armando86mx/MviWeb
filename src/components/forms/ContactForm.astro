---
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '';
---

<form
  class="form"
  action="/api/contacto.php"
  method="POST"
  novalidate
  data-form="contacto"
  aria-describedby="form-help"
>
  <p id="form-help" class="form__help">
    Los campos marcados con <span aria-hidden="true">*</span> son obligatorios.
    Tu mensaje llegará a <strong>contacto@amorygraciapuebla.org</strong>.
  </p>

  <div class="form__row">
    <label class="field">
      <span class="field__label">Nombre <span aria-hidden="true">*</span></span>
      <input type="text" name="nombre" required minlength="2" maxlength="50" autocomplete="given-name" />
    </label>
    <label class="field">
      <span class="field__label">Apellido <span aria-hidden="true">*</span></span>
      <input type="text" name="apellido" required minlength="2" maxlength="50" autocomplete="family-name" />
    </label>
  </div>

  <label class="field">
    <span class="field__label">Correo <span aria-hidden="true">*</span></span>
    <input type="email" name="email" required maxlength="120" autocomplete="email" inputmode="email" />
  </label>

  <label class="field">
    <span class="field__label">Teléfono <span class="field__optional">(opcional)</span></span>
    <input type="tel" name="telefono" maxlength="20" autocomplete="tel" inputmode="tel" />
  </label>

  <label class="field">
    <span class="field__label">Motivo <span aria-hidden="true">*</span></span>
    <select name="motivo" required>
      <option value="" disabled selected>Selecciona una opción</option>
      <option value="visita">Quiero visitar la iglesia</option>
      <option value="oracion">Pedido de oración</option>
      <option value="consulta-pastoral">Consulta pastoral</option>
      <option value="otro">Otro</option>
    </select>
  </label>

  <label class="field">
    <span class="field__label">Mensaje <span aria-hidden="true">*</span></span>
    <textarea name="mensaje" required minlength="10" maxlength="2000" rows={6}></textarea>
  </label>

  <!-- Honeypot: invisible para humanos, visible para bots -->
  <div class="hp" aria-hidden="true">
    <label>No llenar este campo:
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <input type="hidden" name="g-recaptcha-response" data-recaptcha-token />

  <div class="form__actions">
    <button type="submit" class="btn btn--primary btn--lg">Enviar mensaje</button>
    <p class="form__legal">
      Al enviar aceptas nuestro <a href="/aviso-de-privacidad">aviso de privacidad</a>.
    </p>
  </div>

  <p class="form__status" data-form-status role="status" aria-live="polite"></p>
</form>

{recaptchaSiteKey && (
  <script type="text/partytown" src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
)}

<style>
  .form { display: grid; gap: var(--sp-5); max-width: 600px; }
  .form__help { font-size: var(--fs-sm); color: var(--color-fg-muted); }
  .form__row { display: grid; gap: var(--sp-4); }
  @media (min-width: 600px) { .form__row { grid-template-columns: 1fr 1fr; } }

  .field { display: grid; gap: var(--sp-2); }
  .field__label {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-fg);
  }
  .field__optional {
    font-weight: var(--fw-regular);
    color: var(--color-fg-muted);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: var(--fs-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-blanco);
    color: var(--color-fg);
    transition: border-color var(--dur-1) var(--ease-out), box-shadow var(--dur-1) var(--ease-out);
  }
  .field textarea { resize: vertical; min-height: 8rem; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--color-azul-claro);
    box-shadow: 0 0 0 3px var(--color-azul-claro-50);
    outline: none;
  }
  .field input:invalid:not(:placeholder-shown),
  .field textarea:invalid:not(:placeholder-shown) { border-color: var(--color-error); }

  .hp { position: absolute; left: -9999px; top: -9999px; visibility: hidden; }

  .form__actions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
  }
  @media (min-width: 600px) {
    .form__actions { flex-direction: row; align-items: center; }
  }
  .form__legal { font-size: var(--fs-xs); color: var(--color-fg-muted); }

  .form__status:not(:empty) {
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-md);
    background: var(--color-azul-claro-50);
    color: var(--color-azul-deep);
    font-size: var(--fs-sm);
  }
  .form__status[data-state="error"]:not(:empty) {
    background: #fde7e7;
    color: var(--color-error);
  }
</style>

<script define:vars={{ recaptchaSiteKey }}>
  const form = document.querySelector('[data-form="contacto"]');
  const status = document.querySelector('[data-form-status]');
  const tokenInput = document.querySelector('[data-recaptcha-token]');

  async function getRecaptchaToken() {
    if (!recaptchaSiteKey || !window.grecaptcha) return '';
    return new Promise((resolve) => {
      window.grecaptcha.ready(async () => {
        try {
          const t = await window.grecaptcha.execute(recaptchaSiteKey, { action: 'contacto' });
          resolve(t);
        } catch { resolve(''); }
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = 'Enviando…';
    status.removeAttribute('data-state');

    const t = await getRecaptchaToken();
    if (tokenInput) tokenInput.value = t;

    const data = new FormData(form);
    try {
      const r = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (!r.ok) throw new Error(String(r.status));
      const j = await r.json().catch(() => ({}));
      status.textContent = j.message ?? '¡Mensaje enviado! Te responderemos pronto.';
      form.reset();
    } catch (err) {
      status.setAttribute('data-state', 'error');
      status.textContent = 'No pudimos enviar tu mensaje. Inténtalo de nuevo en unos minutos o escríbenos directo a contacto@amorygraciapuebla.org';
    }
  });
</script>
