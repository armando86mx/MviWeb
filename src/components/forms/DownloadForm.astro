---
import Button from '@components/ui/Button.astro';

const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '';
---

<form
  class="form"
  action="/api/descarga.php"
  method="POST"
  novalidate
  data-form="descarga"
  aria-describedby="dl-help"
>
  <p id="dl-help" class="form__help">
    Te enviaremos los tres niveles de la serie Crecer en un solo correo.
    Si no llega en unos minutos, revisa tu carpeta de spam.
  </p>

  <div class="form__row">
    <div class="field" data-field>
      <label class="field__label" for="dl-nombre">Nombre <span aria-hidden="true">*</span></label>
      <input id="dl-nombre" type="text" name="nombre" required minlength="2" maxlength="50" autocomplete="given-name" aria-describedby="dl-nombre-error" data-error-label="tu nombre" />
      <span class="field__error" id="dl-nombre-error" hidden></span>
    </div>
    <div class="field" data-field>
      <label class="field__label" for="dl-apellido">Apellido <span class="field__optional">(opcional)</span></label>
      <input id="dl-apellido" type="text" name="apellido" maxlength="50" autocomplete="family-name" />
    </div>
  </div>

  <div class="field" data-field>
    <label class="field__label" for="dl-email">Correo <span aria-hidden="true">*</span></label>
    <input id="dl-email" type="email" name="email" required maxlength="120" autocomplete="email" inputmode="email" spellcheck="false" autocapitalize="none" aria-describedby="dl-email-hint dl-email-error" data-error-label="tu correo" />
    <span class="field__hint" id="dl-email-hint">Solo lo usaremos para enviarte el material y, si lo decides después, el boletín.</span>
    <span class="field__error" id="dl-email-error" hidden></span>
  </div>

  <div class="hp" aria-hidden="true">
    <label>No llenar este campo:
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <input type="hidden" name="g-recaptcha-response" data-recaptcha-token />

  <div class="form__actions">
    <Button type="submit" variant="primary" size="lg" data-submit>Enviar a mi correo</Button>
    <p class="form__legal">
      Al enviar aceptas nuestro <a href="/aviso-de-privacidad">aviso de privacidad</a>.
    </p>
  </div>

  <p class="form__status" data-form-status role="status" aria-live="polite"></p>
</form>

{recaptchaSiteKey && (
  <script is:inline async src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
)}

<style>
  .form { display: grid; gap: var(--sp-5); max-width: 600px; }
  .form__help { font-size: var(--fs-sm); color: var(--ink-muted); }
  .form__row { display: grid; gap: var(--sp-4); }
  @media (min-width: 600px) { .form__row { grid-template-columns: 1fr 1fr; } }

  .field { display: grid; gap: var(--sp-2); }
  .field__label {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--ink);
  }
  .field__optional { font-weight: var(--fw-regular); color: var(--ink-muted); }
  .field__hint { font-size: var(--fs-xs); color: var(--ink-muted); }
  .field input {
    width: 100%;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: var(--fs-base);
    /* --line-input ≥3:1 sobre paper-100: el campo necesita límite perceptible (1.4.11) */
    border: 1.5px solid var(--line-input);
    border-radius: var(--radius-sm);
    background: var(--paper-100);
    color: var(--ink);
    transition: border-color var(--dur-1) var(--ease), box-shadow var(--dur-1) var(--ease);
  }
  /* El foco lo marca el :focus-visible global (anillo navy 9.9:1);
     el borde ámbar queda solo como acento decorativo */
  .field input:focus {
    border-color: var(--amber-500);
    box-shadow: 0 0 0 3px var(--amber-tint);
  }

  /* Error solo tras interacción (JS), nunca al cargar */
  .field.is-invalid input { border-color: var(--color-error); }
  .field__error { font-size: var(--fs-xs); color: var(--color-error); }
  .field__error[hidden] { display: none; }

  .hp { position: absolute; left: -9999px; top: -9999px; visibility: hidden; }

  .form__actions { display: flex; flex-direction: column; gap: var(--sp-3); align-items: flex-start; }
  @media (min-width: 600px) { .form__actions { flex-direction: row; align-items: center; } }
  .form__legal { font-size: var(--fs-xs); color: var(--ink-muted); }

  .form__status:not(:empty) {
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-md);
    background: var(--amber-tint);
    color: var(--blue-700);
    font-size: var(--fs-sm);
  }
  .form__status[data-state="error"]:not(:empty) {
    background: var(--color-error-bg);
    color: var(--color-error);
  }
</style>

<script define:vars={{ recaptchaSiteKey }}>
  const form = document.querySelector('[data-form="descarga"]');
  const status = form?.querySelector('[data-form-status]');
  const tokenInput = form?.querySelector('[data-recaptcha-token]');
  const submitBtn = form?.querySelector('[data-submit]');

  function messageFor(el) {
    const label = el.dataset.errorLabel || 'este campo';
    const v = el.validity;
    if (v.valueMissing) return `Escribe ${label}.`;
    if (v.typeMismatch && el.type === 'email') return 'Revisa el formato del correo (ej. nombre@correo.com).';
    if (v.tooShort) return `Un poco más largo, por favor (mínimo ${el.minLength} caracteres).`;
    return 'Revisa este campo.';
  }

  function setFieldState(el, touched) {
    const field = el.closest('[data-field]');
    const errorEl = field?.querySelector('.field__error');
    const valid = el.checkValidity();
    if (!field || !errorEl) return valid;
    if (valid || !touched) {
      field.classList.remove('is-invalid');
      el.removeAttribute('aria-invalid');
      errorEl.hidden = true;
      errorEl.textContent = '';
    } else {
      field.classList.add('is-invalid');
      el.setAttribute('aria-invalid', 'true');
      errorEl.hidden = false;
      errorEl.textContent = messageFor(el);
    }
    return valid;
  }

  const controls = form ? [...form.querySelectorAll('input[required]')] : [];
  controls.forEach((el) => {
    el.addEventListener('blur', () => setFieldState(el, true));
    el.addEventListener('input', () => {
      if (el.closest('[data-field]')?.classList.contains('is-invalid')) setFieldState(el, true);
    });
  });

  async function getRecaptchaToken() {
    if (!recaptchaSiteKey || !window.grecaptcha) return '';
    return new Promise((resolve) => {
      window.grecaptcha.ready(async () => {
        try {
          const t = await window.grecaptcha.execute(recaptchaSiteKey, { action: 'descarga' });
          resolve(t);
        } catch { resolve(''); }
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    let firstInvalid = null;
    for (const el of controls) {
      const ok = setFieldState(el, true);
      if (!ok && !firstInvalid) firstInvalid = el;
    }
    if (firstInvalid) {
      firstInvalid.focus();
      status.setAttribute('data-state', 'error');
      status.textContent = 'Revisa los campos marcados antes de enviar.';
      return;
    }

    status.removeAttribute('data-state');
    status.textContent = 'Enviando…';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando…';
    }

    const t = await getRecaptchaToken();
    if (tokenInput) tokenInput.value = t;

    const data = new FormData(form);
    try {
      const r = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (!r.ok) throw new Error(String(r.status));
      const j = await r.json().catch(() => ({}));
      status.textContent = j.message ?? '¡Listo! Revisa tu correo en los próximos minutos.';
      form.reset();
    } catch (err) {
      status.setAttribute('data-state', 'error');
      status.textContent = 'No pudimos procesar tu solicitud. Usa la descarga directa de arriba o escríbenos a contacto@amorygraciapuebla.org';
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar a mi correo';
      }
    }
  });
</script>
