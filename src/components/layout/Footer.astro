---
import { Image } from 'astro:assets';
import { NAV_FOOTER_CONOCE, NAV_FOOTER_EXPLORA, NAV_FOOTER_LEGAL, SITE } from '@lib/site';
import isotipo from '@assets/logos/mvi-isotipo-navy.png';

const year = new Date().getFullYear();

// Solo redes con URL confirmada — nunca placeholders al público
const social = [
  { label: 'Facebook', href: SITE.social.facebook },
  { label: 'Instagram', href: SITE.social.instagram },
  { label: 'YouTube', href: SITE.social.youtube },
].filter((s) => Boolean(s.href));

const whatsapp = SITE.social.whatsapp || '';

// El enlace de preferencias de cookies solo existe si hay analítica configurada
const GA4_ID = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || '';
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <section class="site-footer__brand">
      <a href="/" class="footer-brand" aria-label={`${SITE.name} — inicio`}>
        <span class="footer-brand__mark" aria-hidden="true">
          <Image src={isotipo} alt="" class="footer-brand__iso" width={30} densities={[1, 2]} />
        </span>
        <span class="footer-brand__name">MVI Amor y Gracia</span>
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
      <p class="footer-locale">Iglesia Cristiana Evangélica<br/>Amozoc · Tehuacán · Puebla</p>
    </section>

    <nav class="site-footer__nav" aria-label="Conócenos">
      <h2 class="footer-h">Conócenos</h2>
      <ul>
        {NAV_FOOTER_CONOCE.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__nav" aria-label="Explora el sitio">
      <h2 class="footer-h">Explora</h2>
      <ul>
        {NAV_FOOTER_EXPLORA.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <section class="site-footer__contact">
      <h2 class="footer-h">Contacto</h2>
      <ul>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        {whatsapp && (
          <li>
            <a href={whatsapp} target="_blank" rel="noopener noreferrer">
              WhatsApp pastoral<span class="sr-only"> (se abre en ventana nueva)</span>
            </a>
          </li>
        )}
        <li><a href="/contacto">Escríbenos →</a></li>
      </ul>

      {social.length > 0 && (
        <>
          <h2 class="footer-h footer-h--gap">Síguenos</h2>
          <ul>
            {social.map((s) => (
              <li>
                <a href={s.href} rel="me noopener noreferrer" target="_blank">
                  {s.label}<span class="sr-only"> (se abre en ventana nueva)</span>
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </section>
  </div>

  <div class="site-footer__bar">
    <div class="container site-footer__bar-inner">
      <p>© {year} MVI Amor y Gracia. Todos los derechos reservados.</p>
      <ul class="legal-links">
        {NAV_FOOTER_LEGAL.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
        {GA4_ID && (
          <li><button type="button" class="cookie-prefs" data-open-cookie-prefs>Preferencias de cookies</button></li>
        )}
      </ul>
    </div>
  </div>
</footer>

{GA4_ID && (
  <script is:inline>
    document.querySelector('[data-open-cookie-prefs]')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('mvi:open-cookie-prefs'));
    });
  </script>
)}

<style>
  .site-footer {
    background-color: var(--blue-950);
    color: var(--slate-text);
    margin-top: var(--sp-11);
  }
  /* base.css pinta <p> en negro; dentro del footer navy debe heredar claro */
  .site-footer p { color: inherit; }
  .site-footer a {
    color: var(--slate-text);
    text-decoration: none;
    transition: color var(--dur-link) var(--ease);
  }
  .site-footer a:hover { color: var(--amber-500); }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-block: var(--sp-10) var(--sp-9);
  }
  @media (min-width: 700px) {
    .site-footer__grid { grid-template-columns: 1.4fr 1fr 1fr 1.2fr; }
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
  }
  .footer-brand__mark {
    display: grid;
    place-content: center;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    border-radius: 12px;
    background: var(--cream-text-2);
  }
  .footer-brand__iso { display: block; width: 30px; height: auto; }
  .footer-brand__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: var(--fw-medium);
    color: var(--cream-text-2);
  }
  .footer-tagline {
    margin-top: var(--sp-4);
    font-family: var(--font-display);
    font-style: italic;
    color: var(--amber-500);
    font-size: 1.0625rem;
  }
  .footer-locale {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--footer-muted);
  }

  .footer-h {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: var(--fw-bold);
    color: var(--amber-400);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--sp-3);
  }
  .footer-h--gap { margin-top: var(--sp-6); }

  .site-footer__nav ul,
  .site-footer__contact ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: 14.5px;
  }
  /* Área táctil más generosa por enlace */
  .site-footer__nav a,
  .site-footer__contact a {
    display: inline-block;
    padding-block: var(--sp-2);
  }

  .site-footer__bar {
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .site-footer__bar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
    padding-block: var(--sp-5);
    font-size: var(--fs-xs);
    color: var(--footer-copyright);
  }
  .legal-links {
    display: flex;
    list-style: none;
    margin: 0; padding: 0;
    gap: var(--sp-5);
    flex-wrap: wrap;
    align-items: center;
  }
  .legal-links a { color: var(--footer-copyright); }
  .legal-links a:hover { color: var(--amber-500); }
  .cookie-prefs {
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    color: var(--footer-copyright);
    cursor: pointer;
    transition: color var(--dur-link) var(--ease);
  }
  .cookie-prefs:hover { color: var(--amber-500); }
  @media (min-width: 700px) {
    .site-footer__bar-inner { flex-direction: row; justify-content: space-between; align-items: center; }
  }
</style>
