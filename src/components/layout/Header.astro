---
import { NAV_PRIMARY, NAV_CTA, SITE } from '@lib/site';
import Button from '@components/ui/Button.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActivePath = (href: string) => {
  const cleanHref = href.replace(/\/$/, '') || '/';
  return cleanHref === pathname || (cleanHref !== '/' && pathname.startsWith(cleanHref));
};
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name} — inicio`}>
      <svg viewBox="0 0 64 64" width="40" height="40" aria-hidden="true" class="brand__mark">
        <rect width="64" height="64" rx="12" fill="var(--color-azul-deep)"/>
        <text x="32" y="44" font-family="Fraunces, Georgia, serif" font-size="36" font-weight="700" fill="var(--color-blanco-roto)" text-anchor="middle">A</text>
        <circle cx="48" cy="20" r="4" fill="var(--color-azul-claro)"/>
      </svg>
      <span class="brand__text">
        <span class="brand__name">Amor y Gracia</span>
        <span class="brand__sub">MVI · Puebla</span>
      </span>
    </a>

    <nav aria-label="Navegación principal" class="nav">
      <ul class="nav__list">
        {NAV_PRIMARY.map(({ label, href }) => {
          const isActive = isActivePath(href);
          return (
            <li>
              <a href={href} class={`nav__link ${isActive ? 'is-active' : ''}`} aria-current={isActive ? 'page' : undefined}>{label}</a>
            </li>
          );
        })}
        <li class="nav__cta">
          <Button href={NAV_CTA.href} variant="primary" size="sm">{NAV_CTA.label}</Button>
        </li>
      </ul>
    </nav>

    <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Abrir menú" data-nav-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil" data-mobile-nav hidden>
    <ul class="mobile-nav__list">
      {NAV_PRIMARY.map(({ label, href }) => {
        const isActive = isActivePath(href);
        return (
          <li>
            <a
              href={href}
              class={`mobile-nav__link ${isActive ? 'is-active' : ''}`}
              aria-current={isActive ? 'page' : undefined}
            >{label}</a>
          </li>
        );
      })}
      <li class="mobile-nav__cta">
        <Button href={NAV_CTA.href} variant="primary" fullWidth>{NAV_CTA.label}</Button>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background-color: rgba(250, 250, 250, 0.92);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-2) var(--ease-out), background-color var(--dur-2) var(--ease-out);
  }
  .site-header.is-scrolled {
    border-bottom-color: var(--color-border);
    background-color: rgba(250, 250, 250, 0.97);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    min-height: var(--header-h);
    padding-block: var(--sp-3);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
    color: var(--color-azul-deep);
  }
  .brand__mark { flex: 0 0 auto; border-radius: var(--radius-md); }
  .brand__text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
  }
  .brand__sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-muted);
  }

  .nav { display: none; }
  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    list-style: none;
    margin: 0; padding: 0;
  }
  .nav__link {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    text-decoration: none;
    color: var(--color-fg);
    padding: 0.5rem 0;
    position: relative;
  }
  .nav__link:hover { color: var(--color-azul-deep); }
  .nav__link.is-active { color: var(--color-azul-deep); }
  .nav__link.is-active::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 2px;
    background-color: var(--color-azul-deep);
    border-radius: 2px;
  }
  .nav__cta { margin-left: var(--sp-2); }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    /* Target táctil ≥ 44×44 px */
    min-width: 44px;
    min-height: 44px;
    padding: 10px;
    border-radius: var(--radius-sm);
  }
  .nav-toggle span {
    width: 22px;
    height: 2px;
    background-color: var(--color-azul-deep);
    border-radius: 2px;
    transition: transform var(--dur-2) var(--ease-out), opacity var(--dur-1) var(--ease-out);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-nav {
    border-top: 1px solid var(--color-border);
    background: var(--color-blanco-roto);
    /* En landscape el panel puede ser más alto que el viewport:
       que scrollee él, no que esconda items */
    max-height: calc(100dvh - var(--header-h));
    overflow-y: auto;
  }
  .mobile-nav[hidden] { display: none; }
  .mobile-nav__list {
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0; padding: var(--sp-2) var(--container-pad) var(--sp-5);
  }
  .mobile-nav__link {
    display: block;
    padding: var(--sp-4) 0;
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    text-decoration: none;
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-nav__link.is-active {
    color: var(--color-azul-deep);
    font-weight: var(--fw-semibold);
    box-shadow: inset 3px 0 0 var(--color-azul-deep);
    padding-left: var(--sp-3);
  }
  .mobile-nav__cta { padding-top: var(--sp-4); }

  @media (min-width: 880px) {
    .nav { display: block; }
    .nav-toggle { display: none; }
    .mobile-nav { display: none !important; }
  }
</style>

<script>
  // Sticky header shadow + menú móvil (toggle, Escape, clic fuera)
  const header = document.querySelector('[data-header]');
  const toggle = document.querySelector('[data-nav-toggle]') as HTMLButtonElement | null;
  const mobile = document.querySelector('[data-mobile-nav]') as HTMLElement | null;

  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 4);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (toggle && mobile) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      mobile.hidden = !open;
    };

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!expanded);
    });

    // Escape cierra y devuelve el foco al botón
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobile.hidden) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Clic fuera del header cierra el panel
    document.addEventListener('click', (e) => {
      if (mobile.hidden) return;
      const target = e.target as Node;
      if (header && !header.contains(target)) setOpen(false);
    });
  }
</script>
