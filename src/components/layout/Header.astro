---
import { Image } from 'astro:assets';
import { NAV_PRIMARY, NAV_CTA, SITE } from '@lib/site';
import Button from '@components/ui/Button.astro';
import logo from '@assets/logos/mvi-logo-full.png';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActivePath = (href: string) => {
  const cleanHref = href.replace(/\/$/, '') || '/';
  return cleanHref === pathname || (cleanHref !== '/' && pathname.startsWith(cleanHref));
};
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name} — inicio`}>
      <Image src={logo} alt={SITE.name} class="brand__logo" width={502} height={100} densities={[1, 2]} />
    </a>

    <nav aria-label="Navegación principal" class="nav">
      <ul class="nav__list">
        {NAV_PRIMARY.map(({ label, href }) => {
          const isActive = isActivePath(href);
          return (
            <li>
              <a href={href} class={`nav__link ${isActive ? 'is-active' : ''}`} aria-current={isActive ? 'page' : undefined}>{label}</a>
            </li>
          );
        })}
        <li class="nav__cta">
          <Button href={NAV_CTA.href} variant="primary" size="sm">{NAV_CTA.label}</Button>
        </li>
      </ul>
    </nav>

    <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Abrir menú" data-nav-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil" data-mobile-nav hidden>
    <ul class="mobile-nav__list">
      {NAV_PRIMARY.map(({ label, href }) => {
        const isActive = isActivePath(href);
        return (
          <li>
            <a
              href={href}
              class={`mobile-nav__link ${isActive ? 'is-active' : ''}`}
              aria-current={isActive ? 'page' : undefined}
            >{label}</a>
          </li>
        );
      })}
      <li class="mobile-nav__cta">
        <Button href={NAV_CTA.href} variant="primary" fullWidth>{NAV_CTA.label}</Button>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background-color: var(--paper-400);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid rgba(80,70,50,0.1);
    transition: background-color var(--dur-2) var(--ease-out), box-shadow var(--dur-2) var(--ease-out);
  }
  .site-header.is-scrolled {
    background-color: rgba(239,234,224,0.95);
    box-shadow: var(--shadow-sm);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    min-height: var(--header-h);
    padding-block: 18px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .brand__logo { flex: 0 0 auto; height: 44px; width: auto; display: block; }
  @media (max-width: 420px) {
    .brand__logo { height: 38px; }
  }

  .nav { display: none; }
  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    list-style: none;
    margin: 0; padding: 0;
  }
  .nav__link {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    text-decoration: none;
    color: var(--nav-text);
    padding: 0.5rem 0;
    transition: color var(--dur-link) var(--ease);
  }
  .nav__link:hover { color: var(--ochre-600); }
  .nav__link.is-active {
    font-weight: var(--fw-semibold);
    color: var(--blue-700);
    border-bottom: 2px solid var(--amber-500);
    padding-bottom: 3px;
  }
  .nav__cta { margin-left: var(--sp-2); }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    /* Target táctil ≥ 44×44 px */
    min-width: 44px;
    min-height: 44px;
    padding: 10px;
    border-radius: var(--radius-sm);
  }
  .nav-toggle span {
    width: 22px;
    height: 2px;
    background-color: var(--blue-700);
    border-radius: 2px;
    transition: transform var(--dur-2) var(--ease-out), opacity var(--dur-1) var(--ease-out);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-nav {
    /* Capa sobre el contenido (no empuja el sitio hacia abajo):
       el header sticky es el bloque contenedor */
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    border-top: 1px solid var(--paper-line);
    background: var(--paper-200);
    box-shadow: var(--shadow-lg);
    /* En landscape el panel puede ser más alto que el viewport:
       que scrollee él, no que esconda items */
    max-height: calc(100dvh - var(--header-h));
    overflow-y: auto;
  }
  .mobile-nav[hidden] { display: none; }
  .mobile-nav__list {
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0; padding: var(--sp-2) var(--container-pad) var(--sp-5);
  }
  .mobile-nav__link {
    display: block;
    padding: var(--sp-4) 0;
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    text-decoration: none;
    color: var(--nav-text);
    border-bottom: 1px solid var(--paper-line);
    transition: color var(--dur-link) var(--ease);
  }
  .mobile-nav__link:hover { color: var(--ochre-600); }
  .mobile-nav__link.is-active {
    color: var(--blue-700);
    font-weight: var(--fw-semibold);
    box-shadow: inset 3px 0 0 var(--amber-500);
    padding-left: var(--sp-3);
  }
  .mobile-nav__cta { padding-top: var(--sp-4); }

  @media (min-width: 880px) {
    .nav { display: block; }
    .nav-toggle { display: none; }
    .mobile-nav { display: none !important; }
  }
</style>

<script>
  // Sticky header shadow + menú móvil (toggle, Escape, clic fuera)
  const header = document.querySelector('[data-header]');
  const toggle = document.querySelector('[data-nav-toggle]') as HTMLButtonElement | null;
  const mobile = document.querySelector('[data-mobile-nav]') as HTMLElement | null;

  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 4);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (toggle && mobile) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      mobile.hidden = !open;
      // Con el menú abierto el fondo no se desliza
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!expanded);
    });

    // Escape cierra y devuelve el foco al botón
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobile.hidden) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Clic fuera del header cierra el panel
    document.addEventListener('click', (e) => {
      if (mobile.hidden) return;
      const target = e.target as Node;
      if (header && !header.contains(target)) setOpen(false);
    });

    // Al pasar al layout de escritorio (p. ej. rotar a landscape) el menú
    // se oculta por CSS: cerrar de verdad para no dejar el scroll bloqueado
    window.matchMedia('(min-width: 880px)').addEventListener('change', (e) => {
      if (e.matches && !mobile.hidden) setOpen(false);
    });
  }
</script>
