# Plantilla de variables de entorno — MVI Amor y Gracia
# Copiar a `.env` y rellenar. NUNCA versionar `.env` real en GitHub.
#
# Reglas:
#   - Variables con prefijo PUBLIC_ se exponen al cliente. Pueden ir al repo
#     en .env.example con valores reales si son llaves públicas.
#   - Cualquier secreto (sin PUBLIC_) NO debe terminar en código de cliente.
#     Las credenciales SMTP, secret keys reCAPTCHA y API keys privadas
#     viven en `amorygracia-config.php` fuera de `public_html/`.

PUBLIC_SITE_URL=https://amorygraciapuebla.org

# reCAPTCHA v3 — site key (pública, va al cliente)
PUBLIC_RECAPTCHA_SITE_KEY=

# ConvertKit (Kit) — ID público del formulario
PUBLIC_KIT_FORM_ID=

# Google Analytics 4 — Measurement ID público (real: es llave pública,
# viaja al cliente de todos modos; el gtag solo carga tras consentimiento)
PUBLIC_GA4_MEASUREMENT_ID=G-D7DETX5K6P

# YouTube Data API v3 — usada solo en build time
PUBLIC_YOUTUBE_CHANNEL_ID=
PUBLIC_YOUTUBE_API_KEY=
